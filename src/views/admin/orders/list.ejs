<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Orders</h2>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="small text-uppercase fw-bold text-muted">
                        <th class="px-4 py-3 border-0">Order ID</th>
                        <th class="py-3 border-0">Customer</th>
                        <th class="py-3 border-0">Date</th>
                        <th class="py-3 border-0">Total</th>
                        <th class="py-3 border-0">Status</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td class="px-4 py-3 fw-bold text-dark">#<%= order.order_number || order.id %></td>
                                <td class="py-3">
                                    <div class="fw-semibold text-dark"><%= order.customer_name || 'Guest' %></div>
                                    <small class="text-muted"><%= order.customer_email || '' %></small>
                                </td>
                                <td class="py-3 text-muted"><%= new Date(order.created_at).toLocaleDateString() %></td>
                                <td class="py-3 fw-bold text-dark">$<%= order.total_amount %></td>
                                <td class="py-3">
                                    <% 
                                        let statusClass = 'bg-secondary-subtle text-secondary';
                                        if (order.status === 'completed') statusClass = 'bg-success-subtle text-success';
                                        if (order.status === 'pending') statusClass = 'bg-warning-subtle text-warning';
                                        if (order.status === 'cancelled') statusClass = 'bg-danger-subtle text-danger';
                                    %>
                                    <span class="badge <%= statusClass %> px-3 py-2 rounded-pill small text-uppercase" style="font-size: 0.7rem;"><%= order.status %></span>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <a href="/admin/orders/<%= order.id %>" class="btn btn-sm btn-light border rounded-pill"><i class="fas fa-eye text-primary"></i></a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                No orders found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
