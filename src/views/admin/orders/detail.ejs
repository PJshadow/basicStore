<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
        <a href="/admin/orders" class="btn btn-sm btn-light border rounded-pill me-3"><i class="fas fa-arrow-left"></i></a>
        <h2 class="fw-bold mb-0">Order Details #<%= order.order_number %></h2>
    </div>
    <div>
        <% 
            let statusClass = 'bg-secondary';
            if (order.status === 'delivered') statusClass = 'bg-success';
            if (order.status === 'pending') statusClass = 'bg-warning text-dark';
            if (order.status === 'shipped') statusClass = 'bg-info';
            if (order.status === 'cancelled') statusClass = 'bg-danger';
        %>
        <span class="badge <%= statusClass %> px-3 py-2 rounded-pill text-uppercase" style="font-size: 0.8rem;"><%= order.status %></span>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Order Items -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="fw-bold mb-0">Order Items</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="small text-uppercase fw-bold text-muted">
                                <th class="px-4 py-3 border-0">Product</th>
                                <th class="py-3 border-0">Price</th>
                                <th class="py-3 border-0 text-center">Qty</th>
                                <th class="px-4 py-3 border-0 text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% order.items.forEach(item => { %>
                                <tr>
                                    <td class="px-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-3 overflow-hidden me-3" style="width: 48px; height: 48px;">
                                                <img src="<%= item.product_image || '/images/product-placeholder.png' %>" alt="<%= item.product_name %>" class="w-100 h-100 object-fit-cover">
                                            </div>
                                            <div class="fw-bold text-dark"><%= item.product_name %></div>
                                        </div>
                                    </td>
                                    <td class="py-3">$<%= item.unit_price %></td>
                                    <td class="py-3 text-center"><%= item.quantity %></td>
                                    <td class="px-4 py-3 text-end fw-bold text-dark">$<%= item.total_price %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white border-0 p-4">
                <div class="row justify-content-end">
                    <div class="col-md-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-bold">$<%= order.subtotal %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Shipping</span>
                            <span>$<%= order.shipping_amount %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tax</span>
                            <span>$<%= order.tax_amount %></span>
                        </div>
                        <hr class="my-3">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold h5 mb-0">Total</span>
                            <span class="fw-bold h5 text-primary mb-0">$<%= order.total_amount %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Info -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="fw-bold mb-0">Payment Information</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="fas fa-credit-card"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark">Method: <%= order.payment_method || 'Credit Card' %></div>
                        <small class="text-muted">Status: <%= order.status === 'cancelled' ? 'Refunded' : 'Paid' %></small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Customer Details -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="fw-bold mb-0">Customer</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; font-size: 1.2rem;">
                        <%= order.first_name ? order.first_name.charAt(0) : 'G' %><%= order.last_name ? order.last_name.charAt(0) : '' %>
                    </div>
                    <div>
                        <div class="fw-bold text-dark h6 mb-0"><%= order.first_name %> <%= order.last_name %></div>
                        <small class="text-muted"><%= order.email %></small>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="small text-muted mb-1"><i class="fas fa-envelope me-2"></i>Email</div>
                    <div class="fw-semibold text-dark"><%= order.email %></div>
                </div>
                <div class="mb-0">
                    <div class="small text-muted mb-1"><i class="fas fa-phone me-2"></i>Phone</div>
                    <div class="fw-semibold text-dark"><%= order.phone || 'N/A' %></div>
                </div>
            </div>
        </div>

        <!-- Shipping Address -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="fw-bold mb-0">Shipping Address</h5>
            </div>
            <div class="card-body">
                <div class="text-dark fw-semibold mb-2">
                    <i class="fas fa-map-marker-alt text-primary me-2"></i> Delivery Location
                </div>
                <p class="text-muted mb-0 lh-base">
                    <%= order.shipping_address %>
                </p>
            </div>
        </div>

        <!-- Order Notes -->
        <% if (order.notes) { %>
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0">Order Notes</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-0"><%= order.notes %></p>
                </div>
            </div>
        <% } %>
    </div>
</div>
