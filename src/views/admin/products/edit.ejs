<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Edit Product</h2>
    <a href="/admin/products" class="btn btn-light rounded-pill border px-4">
        <i class="fas fa-arrow-left me-2"></i> Back to List
    </a>
</div>

<% if (typeof product !== 'undefined' && product) { %>
<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
            <form action="/admin/products/<%= product.id %>?_method=PUT" method="POST">
                <div class="mb-4">
                    <label for="name" class="form-label fw-bold">Product Name</label>
                    <input type="text" class="form-control bg-light py-3 border-0" id="name" name="name" value="<%= product.name %>" required>
                </div>
                
                <div class="mb-4">
                    <label for="slug" class="form-label fw-bold">Slug (URL)</label>
                    <input type="text" class="form-control bg-light py-2 border-0" id="slug" name="slug" value="<%= product.slug %>" required>
                </div>
                
                <div class="mb-4">
                    <label for="description" class="form-label fw-bold">Description</label>
                    <textarea class="form-control bg-light border-0" id="description" name="description" rows="5"><%= product.description %></textarea>
                </div>
                
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label for="price" class="form-label fw-bold">Price ($)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-dollar-sign small"></i></span>
                            <input type="number" step="0.01" class="form-control bg-light border-0 py-2" id="price" name="price" value="<%= product.price %>" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="stock_quantity" class="form-label fw-bold">Stock Quantity</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-boxes-stacked small"></i></span>
                            <input type="number" class="form-control bg-light border-0 py-2" id="stock_quantity" name="stock_quantity" value="<%= product.stock_quantity %>" required>
                        </div>
                    </div>
                </div>
                
                <div class="mb-5">
                    <label for="category_id" class="form-label fw-bold">Category</label>
                    <select class="form-select bg-light border-0 py-2" id="category_id" name="category_id" required>
                        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.id %>" <%= product.category_id === category.id ? 'selected' : '' %>>
                                    <%= category.name %>
                                </option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
                
                <hr class="my-5 opacity-10">
                
                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-danger rounded-pill px-4 fw-bold" onclick="document.getElementById('delete-form').submit()">Delete Product</button>
                    <div class="d-flex gap-3">
                        <a href="/admin/products" class="btn btn-light rounded-pill px-4 border fw-bold">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">Update Product</button>
                    </div>
                </div>
            </form>
            
            <form id="delete-form" action="/admin/products/<%= product.id %>?_method=DELETE" method="POST" class="d-none"></form>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h6 class="fw-bold mb-4">Product Image</h6>
            <div class="placeholder-img rounded-4 mb-3" style="height: 250px;">
                <% if (product.image_url) { %>
                    <img src="<%= product.image_url %>" alt="<%= product.name %>" class="img-fluid object-fit-cover w-100 h-100">
                <% } else { %>
                    <i class="fas fa-image fa-3x opacity-25"></i>
                <% } %>
            </div>
            <div class="mb-3">
                <input type="file" class="form-control border-0 bg-light" id="image">
            </div>
            <p class="text-muted small mb-0 text-center">
                Click to change image. <br>Recommended size: 800x800px.
            </p>
        </div>
        
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-light">
            <h6 class="fw-bold mb-3">Product Stats</h6>
            <div class="d-flex justify-content-between mb-2 small">
                <span class="text-muted">Total Sales:</span>
                <span class="fw-bold">45 units</span>
            </div>
            <div class="d-flex justify-content-between mb-2 small">
                <span class="text-muted">Revenue:</span>
                <span class="fw-bold text-success">$2,245.55</span>
            </div>
            <div class="d-flex justify-content-between small">
                <span class="text-muted">View Count:</span>
                <span class="fw-bold">1,204</span>
            </div>
        </div>
    </div>
</div>
<% } else { %>
    <div class="alert alert-warning rounded-4 border-0 shadow-sm p-4">
        <i class="fas fa-exclamation-triangle me-2"></i> Product not found.
    </div>
<% } %>
