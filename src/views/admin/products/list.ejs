<% layout('layouts/main') -%>

<% 
block('title', 'Product Management');
const sidebar = true;
const activePage = 'products';
-%>

<% block('styles', `
    <style>
        .product-image-thumb {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
        }
        .status-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
        }
        .stock-low {
            color: #dc3545;
            font-weight: bold;
        }
        .stock-ok {
            color: #198754;
        }
    </style>
`) -%>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        <i class="bi bi-box-seam me-2"></i> Product Management
    </h1>
    <div>
        <a href="/admin/products/new" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i> Add New Product
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="GET" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Search</label>
                <input type="text" class="form-control" name="search" placeholder="Product name, SKU...">
            </div>
            <div class="col-md-2">
                <label class="form-label">Category</label>
                <select class="form-select" name="category">
                    <option value="">All Categories</option>
                    <option value="1">Electronics</option>
                    <option value="2">Fashion</option>
                    <option value="3">Home & Garden</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" name="status">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Stock</label>
                <select class="form-select" name="stock">
                    <option value="">All</option>
                    <option value="in_stock">In Stock</option>
                    <option value="out_of_stock">Out of Stock</option>
                    <option value="low_stock">Low Stock</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-filter"></i> Filter
                </button>
                <a href="/admin/products" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Products Table -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width: 60px">Image</th>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th class="text-center">Price</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Sample Data - In real app, this would come from database -->
                    <tr>
                        <td>
                            <img src="https://via.placeholder.com/60x60/6c757d/ffffff?text=HP" 
                                 class="product-image-thumb" alt="Headphones">
                        </td>
                        <td>
                            <strong>Wireless Headphones</strong>
                            <div class="text-muted small">Premium sound quality with noise cancellation</div>
                        </td>
                        <td>SKU-001</td>
                        <td>Electronics</td>
                        <td class="text-center">
                            <div>$99.99</div>
                            <div class="text-success small">$89.99 <small>(sale)</small></div>
                        </td>
                        <td class="text-center">
                            <span class="stock-ok">50</span>
                            <div class="text-muted small">Threshold: 5</div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-success status-badge">Active</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/admin/products/1/edit" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/products/wireless-headphones" target="_blank" class="btn btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <img src="https://via.placeholder.com/60x60/0dcaf0/ffffff?text=SW" 
                                 class="product-image-thumb" alt="Smart Watch">
                        </td>
                        <td>
                            <strong>Smart Watch</strong>
                            <div class="text-muted small">Track fitness, receive notifications</div>
                        </td>
                        <td>SKU-002</td>
                        <td>Electronics</td>
                        <td class="text-center">
                            <div>$199.99</div>
                        </td>
                        <td class="text-center">
                            <span class="stock-low">3</span>
                            <div class="text-danger small">Low stock!</div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-success status-badge">Active</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/admin/products/2/edit" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/products/smart-watch" target="_blank" class="btn btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <img src="https://via.placeholder.com/60x60/198754/ffffff?text=BP" 
                                 class="product-image-thumb" alt="Backpack">
                        </td>
                        <td>
                            <strong>Backpack</strong>
                            <div class="text-muted small">Durable water-resistant backpack</div>
                        </td>
                        <td>SKU-003</td>
                        <td>Fashion</td>
                        <td class="text-center">
                            <div>$49.99</div>
                        </td>
                        <td class="text-center">
                            <span class="stock-ok">100</span>
                            <div class="text-muted small">Threshold: 5</div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-success status-badge">Active</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/admin/products/3/edit" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/products/backpack" target="_blank" class="btn btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <img src="https://via.placeholder.com/60x60/ffc107/ffffff?text=CM" 
                                 class="product-image-thumb" alt="Coffee Maker">
                        </td>
                        <td>
                            <strong>Coffee Maker</strong>
                            <div class="text-muted small">Programmable 12-cup coffee maker</div>
                        </td>
                        <td>SKU-004</td>
                        <td>Home & Garden</td>
                        <td class="text-center">
                            <div>$79.99</div>
                        </td>
                        <td class="text-center">
                            <span class="stock-ok">25</span>
                            <div class="text-muted small">Threshold: 5</div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-warning status-badge">Inactive</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/admin/products/4/edit" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/products/coffee-maker" target="_blank" class="btn btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Previous</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#">Next</a>
                </li>
            </ul>
        </nav>
        
        <!-- Summary -->
        <div class="row mt-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center py-3">
                        <h5 class="card-title mb-1">Total Products</h5>
                        <div class="display-6">4</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center py-3">
                        <h5 class="card-title mb-1">Active</h5>
                        <div class="display-6">3</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body text-center py-3">
                        <h5 class="card-title mb-1">Low Stock</h5>
                        <div class="display-6">1</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center py-3">
                        <h5 class="card-title mb-1">Out of Stock</h5>
                        <div class="display-6">0</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<% block('scripts', `
    <script>
        // Delete confirmation
        document.querySelectorAll('.btn-outline-danger').forEach(button => {
            button.addEventListener('click', function() {
                if (confirm('Are you sure you want to delete this product? This action cannot be undone.')) {
                    // In a real app, you would submit a delete request
                    alert('Product deletion would be processed here.');
                }
            });
        });
    </script>
`) -%>