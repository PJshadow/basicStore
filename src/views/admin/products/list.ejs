<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Products</h2>
    <a href="/admin/products/new" class="btn btn-primary rounded-pill px-4">
        <i class="fas fa-plus me-2"></i> Add Product
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="small text-uppercase fw-bold text-muted">
                        <th class="px-4 py-3 border-0">Product</th>
                        <th class="py-3 border-0">Category</th>
                        <th class="py-3 border-0">Price</th>
                        <th class="py-3 border-0">Stock</th>
                        <th class="py-3 border-0">Status</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof products !== 'undefined' && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <tr>
                                <td class="px-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="d-flex bg-light rounded-3 overflow-hidden me-3 p-1" style="gap: 2px;">
                                            <% if (product.images && product.images.length > 0) { %>
                                                <% product.images.slice(0, 3).forEach(img => { %>
                                                    <div style="width: 24px; height: 24px;">
                                                        <img src="<%= img.image_url %>" alt="<%= product.name %>" class="img-fluid object-fit-cover w-100 h-100 rounded-1 <%= img.is_main ? 'border border-primary' : '' %>">
                                                    </div>
                                                <% }) %>
                                                <% if (product.images.length > 3) { %>
                                                    <div class="small text-muted d-flex align-items-center justify-content-center" style="width: 24px; height: 24px; font-size: 10px;">
                                                        +<%= product.images.length - 3 %>
                                                    </div>
                                                <% } %>
                                            <% } else { %>
                                                <div class="placeholder-img h-100 small d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;"><i class="fas fa-image"></i></div>
                                            <% } %>
                                        </div>
                                        <div class="fw-bold text-dark"><%= product.name %></div>
                                    </div>
                                </td>
                                <td class="py-3"><span class="badge bg-light text-muted"><%= product.category_name || 'General' %></span></td>
                                <td class="py-3 fw-bold text-dark">$<%= product.price %></td>
                                <td class="py-3">
                                    <% if (product.stock_quantity <= 5) { %>
                                        <span class="text-danger fw-bold"><i class="fas fa-triangle-exclamation me-1"></i> <%= product.stock_quantity %></span>
                                    <% } else { %>
                                        <span class="text-muted"><%= product.stock_quantity %></span>
                                    <% } %>
                                </td>
                                <td class="py-3">
                                    <% if (product.active) { %>
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill small">Active</span>
                                    <% } else { %>
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill small">Inactive</span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <div class="btn-group">
                                        <a href="/admin/products/<%= product.id %>/edit" class="btn btn-sm btn-light border rounded-pill me-2"><i class="fas fa-edit text-primary"></i></a>
                                        <form action="/admin/products/<%= product.id %>?_method=DELETE" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light border rounded-pill" onclick="return confirm('Are you sure?')"><i class="fas fa-trash text-danger"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                No products found. <a href="/admin/products/new">Create one</a>.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
