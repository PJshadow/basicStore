<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Add New Product</h2>
    <a href="/admin/products" class="btn btn-light rounded-pill border px-4">
        <i class="fas fa-arrow-left me-2"></i> Back to List
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
            <form action="/admin/products" method="POST">
                <div class="mb-4">
                    <label for="name" class="form-label fw-bold">Product Name</label>
                    <input type="text" class="form-control bg-light py-3 border-0" id="name" name="name" placeholder="Enter product name" required>
                </div>
                
                <div class="mb-4">
                    <label for="slug" class="form-label fw-bold">Slug (URL)</label>
                    <input type="text" class="form-control bg-light py-2 border-0" id="slug" name="slug" placeholder="product-name-slug">
                    <small class="text-muted">Unique identifier for the product URL. Leave blank to auto-generate.</small>
                </div>
                
                <div class="mb-4">
                    <label for="description" class="form-label fw-bold">Description</label>
                    <textarea class="form-control bg-light border-0" id="description" name="description" rows="5" placeholder="Enter product description"></textarea>
                </div>
                
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label for="price" class="form-label fw-bold">Price ($)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-dollar-sign small"></i></span>
                            <input type="number" step="0.01" class="form-control bg-light border-0 py-2" id="price" name="price" placeholder="0.00" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="stock_quantity" class="form-label fw-bold">Stock Quantity</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-boxes-stacked small"></i></span>
                            <input type="number" class="form-control bg-light border-0 py-2" id="stock_quantity" name="stock_quantity" placeholder="0" required>
                        </div>
                    </div>
                </div>
                
                <div class="mb-5">
                    <label for="category_id" class="form-label fw-bold">Category</label>
                    <select class="form-select bg-light border-0 py-2" id="category_id" name="category_id" required>
                        <option value="">Select a category</option>
                        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.id %>"><%= category.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
                
                <hr class="my-5 opacity-10">
                
                <div class="d-flex justify-content-end gap-3">
                    <button type="reset" class="btn btn-light rounded-pill px-5 border fw-bold">Reset</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">Save Product</button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h6 class="fw-bold mb-4">Product Image</h6>
            <div class="placeholder-img rounded-4 mb-3" style="height: 250px;">
                <i class="fas fa-cloud-arrow-up fa-3x opacity-25"></i>
            </div>
            <div class="mb-3">
                <input type="file" class="form-control border-0 bg-light" id="image">
            </div>
            <p class="text-muted small mb-0 text-center">
                Click to upload or drag and drop. <br>Recommended size: 800x800px.
            </p>
        </div>
        
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white">
            <h6 class="fw-bold mb-3"><i class="fas fa-lightbulb me-2"></i> Pro Tip</h6>
            <p class="small mb-0 opacity-90">
                Good product descriptions and high-quality images can increase sales by up to 40%. Make sure to include key features and benefits!
            </p>
        </div>
    </div>
</div>
