<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Add New Category</h2>
    <a href="/admin/categories" class="btn btn-light rounded-pill border px-4">
        <i class="fas fa-arrow-left me-2"></i> Back to List
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
    <form action="/admin/categories" method="POST">
        <div class="mb-4">
            <label for="name" class="form-label fw-bold">Category Name</label>
            <input type="text" class="form-control bg-light py-3 border-0" id="name" name="name" required placeholder="Enter category name">
        </div>
        
        <div class="mb-4">
            <label for="slug" class="form-label fw-bold">Slug (URL)</label>
            <input type="text" class="form-control bg-light py-2 border-0" id="slug" name="slug" placeholder="category-name-slug">
            <small class="text-muted">Unique identifier for the category URL. Leave blank to auto-generate.</small>
        </div>
        
        <div class="mb-4">
            <label for="description" class="form-label fw-bold">Description</label>
            <textarea class="form-control bg-light border-0" id="description" name="description" rows="5" placeholder="Enter category description"></textarea>
        </div>
        
        <div class="d-flex justify-content-end gap-3">
            <button type="reset" class="btn btn-light rounded-pill px-5 border fw-bold">Reset</button>
            <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                <i class="fas fa-save me-2"></i> Save Category
            </button>
        </div>
    </form>
</div>
