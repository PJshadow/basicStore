<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">Create New Coupon</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/coupons">Coupons</a></li>
                <li class="breadcrumb-item active">New</li>
            </ol>
        </nav>
    </div>
    <a href="/admin/coupons" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="fas fa-arrow-left me-2"></i> Back to List
    </a>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <form action="/admin/coupons" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="code" class="form-label small fw-bold text-uppercase">Coupon Code *</label>
                            <input type="text" class="form-control rounded-3" id="code" name="code" value="<%= typeof coupon !== 'undefined' ? coupon.code : '' %>" required placeholder="SUMMER2026">
                        </div>
                        <div class="col-md-6">
                            <label for="active" class="form-label d-block small fw-bold text-uppercase">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="active" name="active" <%= typeof coupon === 'undefined' || coupon.active === 'on' || coupon.active === true ? 'checked' : '' %>>
                                <label class="form-check-label" for="active">Active</label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="discount_type" class="form-label small fw-bold text-uppercase">Discount Type *</label>
                            <select class="form-select rounded-3" id="discount_type" name="discount_type" required>
                                <option value="percentage" <%= typeof coupon !== 'undefined' && coupon.discount_type === 'percentage' ? 'selected' : '' %>>Percentage (%)</option>
                                <option value="fixed" <%= typeof coupon !== 'undefined' && coupon.discount_type === 'fixed' ? 'selected' : '' %>>Fixed Amount ($)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="discount_value" class="form-label small fw-bold text-uppercase">Discount Value *</label>
                            <input type="number" step="0.01" class="form-control rounded-3" id="discount_value" name="discount_value" value="<%= typeof coupon !== 'undefined' ? coupon.discount_value : '' %>" required placeholder="0.00">
                        </div>

                        <div class="col-md-6">
                            <label for="minimum_order" class="form-label small fw-bold text-uppercase">Min Order Amount ($)</label>
                            <input type="number" step="0.01" class="form-control rounded-3" id="minimum_order" name="minimum_order" value="<%= typeof coupon !== 'undefined' ? coupon.minimum_order : '0.00' %>" placeholder="0.00">
                        </div>
                        <div class="col-md-6">
                            <label for="maximum_discount" class="form-label small fw-bold text-uppercase">Max Discount ($)</label>
                            <input type="number" step="0.01" class="form-control rounded-3" id="maximum_discount" name="maximum_discount" value="<%= typeof coupon !== 'undefined' ? coupon.maximum_discount : '' %>" placeholder="Optional">
                            <div class="form-text small text-muted">Only for percentage discounts.</div>
                        </div>

                        <div class="col-md-12">
                            <label for="description" class="form-label small fw-bold text-uppercase">Description</label>
                            <textarea class="form-control rounded-3" id="description" name="description" rows="2" placeholder="Describe this coupon..."><%= typeof coupon !== 'undefined' ? coupon.description : '' %></textarea>
                        </div>

                        <div class="col-md-12">
                            <label for="usage_limit" class="form-label small fw-bold text-uppercase">Total Usage Limit</label>
                            <input type="number" class="form-control rounded-3" id="usage_limit" name="usage_limit" value="<%= typeof coupon !== 'undefined' ? coupon.usage_limit : '' %>" placeholder="Optional">
                        </div>

                        <div class="col-md-6">
                            <label for="valid_from" class="form-label small fw-bold text-uppercase">Valid From</label>
                            <input type="date" class="form-control rounded-3" id="valid_from" name="valid_from" value="<%= typeof coupon !== 'undefined' ? coupon.valid_from : '' %>">
                        </div>
                        <div class="col-md-6">
                            <label for="valid_until" class="form-label small fw-bold text-uppercase">Valid Until</label>
                            <input type="date" class="form-control rounded-3" id="valid_until" name="valid_until" value="<%= typeof coupon !== 'undefined' ? coupon.valid_until : '' %>">
                        </div>

                        <div class="col-12 mt-4">
                            <hr class="text-muted opacity-25">
                            <div class="d-flex justify-content-end gap-2">
                                <button type="reset" class="btn btn-light rounded-pill px-4">Reset</button>
                                <button type="submit" class="btn btn-primary rounded-pill px-4">Create Coupon</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
