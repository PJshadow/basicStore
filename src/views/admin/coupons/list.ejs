<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Coupons</h2>
    <a href="/admin/coupons/new" class="btn btn-primary rounded-pill px-4">
        <i class="fas fa-plus me-2"></i> Create Coupon
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="small text-uppercase fw-bold text-muted">
                        <th class="px-4 py-3 border-0">Code</th>
                        <th class="py-3 border-0">Discount</th>
                        <th class="py-3 border-0">Usage</th>
                        <th class="py-3 border-0">Expiry</th>
                        <th class="py-3 border-0">Status</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof coupons !== 'undefined' && coupons.length > 0) { %>
                        <% coupons.forEach(coupon => { %>
                            <tr>
                                <td class="px-4 py-3">
                                    <code class="bg-primary-subtle text-primary px-3 py-2 rounded fw-bold border border-primary-subtle"><%= coupon.code %></code>
                                </td>
                                <td class="py-3 fw-bold text-dark">
                                    <%= coupon.discount_type === 'percentage' ? coupon.discount_value + '%' : '$' + coupon.discount_value %>
                                </td>
                                <td class="py-3 text-muted small">
                                    <%= coupon.used_count || 0 %> / <%= coupon.usage_limit || '∞' %>
                                </td>
                                <td class="py-3 text-muted small">
                                    <%= coupon.expiry_date ? new Date(coupon.expiry_date).toLocaleDateString() : 'Never' %>
                                </td>
                                <td class="py-3">
                                    <% 
                                        const isExpired = coupon.expiry_date && new Date(coupon.expiry_date) < new Date();
                                        const statusClass = isExpired ? 'bg-danger-subtle text-danger' : 'bg-success-subtle text-success';
                                        const statusLabel = isExpired ? 'Expired' : 'Active';
                                    %>
                                    <span class="badge <%= statusClass %> px-3 py-2 rounded-pill small"><%= statusLabel %></span>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <div class="btn-group">
                                        <a href="/admin/coupons/<%= coupon.id %>/edit" class="btn btn-sm btn-light border rounded-pill me-2"><i class="fas fa-edit text-primary"></i></a>
                                        <form action="/admin/coupons/<%= coupon.id %>?_method=DELETE" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light border rounded-pill" onclick="return confirm('Are you sure?')"><i class="fas fa-trash text-danger"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                No coupons found. <a href="/admin/coupons/new">Create one</a>.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
