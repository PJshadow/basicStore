<div id="example-dashboard-container" class="mt-5 pt-5 border-top position-relative" style="display: none;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 text-muted">
            <i class="fas fa-vial me-2"></i> Dashboard Example (Fake Data Preview)
        </h2>
        <button type="button" class="btn-close" id="close-example-dashboard" aria-label="Close"></button>
    </div>
    <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-info-circle me-3 fa-lg"></i>
        <div>
            This is an example of how the dashboard will look once you have more data in your database.
        </div>
    </div>

    <!-- Fake Stats Cards -->
    <div class="row mb-4 opacity-75">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total Revenue
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">$24,580</div>
                            <div class="mt-2 mb-0 text-muted text-xs">
                                <span class="text-success mr-2">
                                    <i class="fas fa-arrow-up"></i> 12.5%
                                </span>
                                <span>Since last month</span>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-dollar-sign stat-icon text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Total Orders
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">1,248</div>
                            <div class="mt-2 mb-0 text-muted text-xs">
                                <span class="text-success mr-2">
                                    <i class="fas fa-arrow-up"></i> 8.3%
                                </span>
                                <span>Since last month</span>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-shopping-cart stat-icon text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Total Customers
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">892</div>
                            <div class="mt-2 mb-0 text-muted text-xs">
                                <span class="text-success mr-2">
                                    <i class="fas fa-arrow-up"></i> 5.2%
                                </span>
                                <span>Since last month</span>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users stat-icon text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Low Stock Items
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">18</div>
                            <div class="mt-2 mb-0 text-muted text-xs">
                                <span class="text-danger mr-2">
                                    <i class="fas fa-arrow-down"></i> 3.1%
                                </span>
                                <span>Since last month</span>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle stat-icon text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Fake Activity and Orders -->
    <div class="row opacity-75">
        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Recent Activity Example</h6>
                </div>
                <div class="card-body">
                    <div class="activity-feed">
                        <div class="activity-item d-flex mb-3">
                            <div class="activity-icon bg-primary text-white rounded-circle me-3">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                            <div>
                                <h6 class="mb-0">New Order #ORD-1001</h6>
                                <p class="text-muted mb-0">John Doe placed a new order</p>
                                <small class="text-muted">10 minutes ago</small>
                            </div>
                        </div>
                        <div class="activity-item d-flex mb-3">
                            <div class="activity-icon bg-success text-white rounded-circle me-3">
                                <i class="fas fa-user-plus"></i>
                            </div>
                            <div>
                                <h6 class="mb-0">New Customer Registered</h6>
                                <p class="text-muted mb-0">Jane Smith created an account</p>
                                <small class="text-muted">45 minutes ago</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-8 col-lg-7 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Recent Orders Example</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>#ORD-1001</td>
                                    <td>John Doe</td>
                                    <td>$249.99</td>
                                    <td><span class="badge bg-warning">Processing</span></td>
                                </tr>
                                <tr>
                                    <td>#ORD-1000</td>
                                    <td>Jane Smith</td>
                                    <td>$129.99</td>
                                    <td><span class="badge bg-success">Shipped</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const exampleContainer = document.getElementById('example-dashboard-container');
        const closeBtn = document.getElementById('close-example-dashboard');
        
        // Check if user has already closed the example
        if (localStorage.getItem('hideAdminExampleDashboard') !== 'true') {
            exampleContainer.style.display = 'block';
        }
        
        closeBtn.addEventListener('click', function() {
            exampleContainer.style.display = 'none';
            // Save preference to localStorage
            localStorage.setItem('hideAdminExampleDashboard', 'true');
        });
    });
</script>
