<div class="card mb-3">
    <div class="card-header bg-primary text-white">
        <i class="fas fa-user-circle me-2"></i> Admin Panel
    </div>
    <div class="list-group list-group-flush">
        <a href="/admin" class="list-group-item list-group-item-action <%= (activePage === 'dashboard') ? 'active' : '' %>">
            <i class="fas fa-tachometer-alt me-2"></i> Dashboard
        </a>
        
        <div class="list-group-item">
            <small class="text-muted">PRODUCT MANAGEMENT</small>
        </div>
        <a href="/admin/products" class="list-group-item list-group-item-action <%= (activePage === 'products') ? 'active' : '' %>">
            <i class="fas fa-box me-2"></i> All Products
        </a>
        <a href="/admin/products/new" class="list-group-item list-group-item-action">
            <i class="fas fa-plus-circle me-2"></i> Add New Product
        </a>
        <a href="/admin/categories" class="list-group-item list-group-item-action">
            <i class="fas fa-tags me-2"></i> Categories
        </a>
        
        <div class="list-group-item">
            <small class="text-muted">SALES & ORDERS</small>
        </div>
        <a href="/admin/orders" class="list-group-item list-group-item-action <%= (activePage === 'orders') ? 'active' : '' %>">
            <i class="fas fa-shopping-cart me-2"></i> Orders
            <span class="badge bg-danger float-end">5</span>
        </a>
        <a href="/admin/customers" class="list-group-item list-group-item-action <%= (activePage === 'customers') ? 'active' : '' %>">
            <i class="fas fa-users me-2"></i> Customers
        </a>
        
        <div class="list-group-item">
            <small class="text-muted">MARKETING</small>
        </div>
        <a href="/admin/coupons" class="list-group-item list-group-item-action <%= (activePage === 'coupons') ? 'active' : '' %>">
            <i class="fas fa-tag me-2"></i> Coupons
        </a>
        
        <div class="list-group-item">
            <small class="text-muted">REPORTS</small>
        </div>
        <a href="/admin/reports/sales" class="list-group-item list-group-item-action <%= (activePage === 'reports') ? 'active' : '' %>">
            <i class="fas fa-chart-line me-2"></i> Sales Reports
        </a>
        <a href="/admin/reports/inventory" class="list-group-item list-group-item-action">
            <i class="fas fa-chart-pie me-2"></i> Inventory Reports
        </a>
        
        <div class="list-group-item">
            <small class="text-muted">SETTINGS</small>
        </div>
        <a href="/admin/settings" class="list-group-item list-group-item-action <%= (activePage === 'settings') ? 'active' : '' %>">
            <i class="fas fa-cog me-2"></i> Store Settings
        </a>
        <a href="/admin/users" class="list-group-item list-group-item-action">
            <i class="fas fa-user-shield me-2"></i> User Management
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header bg-info text-white">
        <i class="fas fa-chart-bar me-2"></i> Quick Stats
    </div>
    <div class="card-body p-3">
        <div class="d-flex justify-content-between mb-2">
            <small>Today's Orders</small>
            <strong>12</strong>
        </div>
        <div class="d-flex justify-content-between mb-2">
            <small>Pending Orders</small>
            <strong class="text-warning">5</strong>
        </div>
        <div class="d-flex justify-content-between mb-2">
            <small>Low Stock Items</small>
            <strong class="text-danger">3</strong>
        </div>
        <div class="d-flex justify-content-between">
            <small>Total Revenue</small>
            <strong class="text-success">$2,450</strong>
        </div>
    </div>
</div>