<div class="row g-4 py-5">
    <div class="col-lg-3">
        <%- include('../partials/sidebar') %>
    </div>
    
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
            <h2 class="fw-bold mb-5">My Orders</h2>
            
            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-light">
                            <tr class="small text-uppercase fw-bold text-muted">
                                <th class="px-4 py-3 border-0">Order</th>
                                <th class="py-3 border-0">Date</th>
                                <th class="py-3 border-0">Status</th>
                                <th class="py-3 border-0 text-end">Total</th>
                                <th class="px-4 py-3 border-0"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                                <tr>
                                    <td class="px-4 py-3 fw-bold text-dark">#<%= order.order_number || order.id %></td>
                                    <td class="py-3 text-muted"><%= new Date(order.created_at).toLocaleDateString() %></td>
                                    <td class="py-3">
                                        <% 
                                            let statusClass = 'bg-secondary-subtle text-secondary';
                                            if (order.status === 'completed') statusClass = 'bg-success-subtle text-success';
                                            if (order.status === 'pending') statusClass = 'bg-warning-subtle text-warning';
                                        %>
                                        <span class="badge <%= statusClass %> px-3 py-2 rounded-pill small"><%= order.status %></span>
                                    </td>
                                    <td class="py-3 text-end fw-bold text-dark">$<%= order.total_amount %></td>
                                    <td class="px-4 py-3 text-end">
                                        <a href="/orders/<%= order.id %>" class="btn btn-sm btn-light border rounded-pill px-3 fw-bold">Details</a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <div class="mb-4 opacity-10"><i class="fas fa-box-open fa-5x"></i></div>
                    <h4 class="fw-bold mb-3">No orders yet</h4>
                    <p class="text-muted mb-5">You haven't placed any orders with us yet. Start shopping and find something you love!</p>
                    <a href="/products" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-sm">Explore Products</a>
                </div>
            <% } %>
        </div>
    </div>
</div>
