<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - <%= siteName || 'BasicStore' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .profile-card {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 20px;
        }
        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background-color: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: bold;
            color: #495057;
            margin: 0 auto 20px;
        }
        .profile-avatar.editable {
            position: relative;
            cursor: pointer;
        }
        .profile-avatar.editable:hover::after {
            content: 'Change';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background-color: rgba(0,0,0,0.7);
            color: white;
            padding: 5px;
            font-size: 0.8rem;
            border-radius: 0 0 50% 50%;
        }
        .nav-tabs .nav-link {
            color: #495057;
            border: none;
            padding: 12px 20px;
        }
        .nav-tabs .nav-link.active {
            color: #0d6efd;
            background-color: #f8f9fa;
            border-bottom: 3px solid #0d6efd;
        }
        .tab-content {
            padding: 25px;
            border: 1px solid #dee2e6;
            border-top: none;
            border-radius: 0 0 8px 8px;
        }
        .form-section {
            margin-bottom: 30px;
        }
        .form-section h5 {
            padding-bottom: 10px;
            margin-bottom: 20px;
            border-bottom: 1px solid #dee2e6;
        }
    </style>
</head>
<body>
    <%- include('../layouts/main') %>

    <div class="container py-4">
        <div class="row">
            <!-- Customer Sidebar -->
            <div class="col-lg-3 mb-4">
                <div class="profile-card text-center">
                    <div class="profile-avatar editable" onclick="document.getElementById('avatarInput').click()">
                        <%= customer.initials || 'CU' %>
                    </div>
                    <input type="file" id="avatarInput" accept="image/*" style="display: none;" onchange="uploadAvatar(event)">
                    
                    <h5 class="mb-2"><%= customer.fullName %></h5>
                    <p class="text-muted mb-3"><%= customer.email %></p>
                    
                    <div class="d-grid gap-2">
                        <a href="/customer/orders" class="btn btn-outline-primary">
                            <i class="bi bi-bag me-2"></i> My Orders
                        </a>
                        <a href="/customer/wishlist" class="btn btn-outline-secondary">
                            <i class="bi bi-heart me-2"></i> Wishlist
                        </a>
                        <a href="/logout" class="btn btn-outline-danger">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </a>
                    </div>
                    
                    <div class="mt-4 pt-3 border-top">
                        <h6 class="text-muted mb-3">Account Details</h6>
                        <div class="text-start">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Member Since:</span>
                                <strong><%= new Date(customer.createdAt).toLocaleDateString() %></strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Total Orders:</span>
                                <strong><%= stats.totalOrders || 0 %></strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Total Spent:</span>
                                <strong>$<%= stats.totalSpent ? stats.totalSpent.toFixed(2) : '0.00' %></strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="h3 mb-0">My Profile</h1>
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
                            <i class="bi bi-printer me-2"></i> Print
                        </button>
                        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                            <i class="bi bi-trash me-2"></i> Delete Account
                        </button>
                    </div>
                </div>

                <!-- Tabs -->
                <ul class="nav nav-tabs" id="profileTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button" role="tab">
                            <i class="bi bi-person me-2"></i> Personal Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="address-tab" data-bs-toggle="tab" data-bs-target="#address" type="button" role="tab">
                            <i class="bi bi-geo-alt me-2"></i> Addresses
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="security-tab" data-bs-toggle="tab" data-bs-target="#security" type="button" role="tab">
                            <i class="bi bi-shield-lock me-2"></i> Security
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="preferences-tab" data-bs-toggle="tab" data-bs-target="#preferences" type="button" role="tab">
                            <i class="bi bi-gear me-2"></i> Preferences
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="profileTabsContent">
                    <!-- Personal Info Tab -->
                    <div class="tab-pane fade show active" id="personal" role="tabpanel">
                        <form id="personalForm" onsubmit="updatePersonalInfo(event)">
                            <div class="form-section">
                                <h5>Basic Information</h5>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="firstName" class="form-label">First Name *</label>
                                        <input type="text" class="form-control" id="firstName" name="firstName" value="<%= customer.first_name %>" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="lastName" class="form-label">Last Name *</label>
                                        <input type="text" class="form-control" id="lastName" name="lastName" value="<%= customer.last_name %>" required>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="email" class="form-label">Email Address *</label>
                                        <input type="email" class="form-control" id="email" name="email" value="<%= customer.email %>" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="phone" class="form-label">Phone Number</label>
                                        <input type="tel" class="form-control" id="phone" name="phone" value="<%= customer.phone || '' %>">
                                    </div>
                                </div>
                            </div>

                            <div class="form-section">
                                <h5>Additional Information</h5>
                                <div class="mb-3">
                                    <label for="birthDate" class="form-label">Date of Birth</label>
                                    <input type="date" class="form-control" id="birthDate" name="birthDate" value="<%= customer.birth_date || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label for="gender" class="form-label">Gender</label>
                                    <select class="form-select" id="gender" name="gender">
                                        <option value="">Select Gender</option>
                                        <option value="male" <%= customer.gender === 'male' ? 'selected' : '' %>>Male</option>
                                        <option value="female" <%= customer.gender === 'female' ? 'selected' : '' %>>Female</option>
                                        <option value="other" <%= customer.gender === 'other' ? 'selected' : '' %>>Other</option>
                                        <option value="prefer_not_to_say" <%= customer.gender === 'prefer_not_to_say' ? 'selected' : '' %>>Prefer not to say</option>
                                    </select>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle me-2"></i> Save Changes
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Addresses Tab -->
                    <div class="tab-pane fade" id="address" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0">Saved Addresses</h5>
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                                <i class="bi bi-plus-circle me-2"></i> Add New Address
                            </button>
                        </div>

                        <% if (addresses && addresses.length > 0) { %>
                            <div class="row">
                                <% addresses.forEach(address => { %>
                                    <div class="col-md-6 mb-3">
                                        <div class="card h-100 <%= address.is_default ? 'border-primary' : '' %>">
                                            <div class="card-body">
                                                <% if (address.is_default) { %>
                                                    <span class="badge bg-primary mb-2">Default</span>
                                                <% } %>
                                                <h6 class="card-title"><%= address.label || 'Address' %></h6>
                                                <p class="card-text">
                                                    <%= address.street %><br>
                                                    <% if (address.street2) { %><%= address.street2 %><br><% } %>
                                                    <%= address.city %>, <%= address.state %> <%= address.zip_code %><br>
                                                    <%= address.country %>
                                                </p>
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-secondary" onclick="editAddress('<%= address.id %>')">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <% if (!address.is_default) { %>
                                                        <button type="button" class="btn btn-outline-primary" onclick="setDefaultAddress('<%= address.id %>')">
                                                            <i class="bi bi-star"></i>
                                                        </button>
                                                    <% } %>
                                                    <button type="button" class="btn btn-outline-danger" onclick="deleteAddress('<%= address.id %>')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="bi bi-geo-alt" style="font-size: 3rem; color: #6c757d;"></i>
                                <h5 class="mt-3">No addresses saved</h5>
                                <p class="text-muted">Add your first address to make checkout faster.</p>
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                                    <i class="bi bi-plus-circle me-2"></i> Add Address
                                </button>
                            </div>
                        <% } %>
                    </div>

                    <!-- Security Tab -->
                    <div class="tab-pane fade" id="security" role="tabpanel">
                        <form id="securityForm" onsubmit="updateSecurity(event)">
                            <div class="form-section">
                                <h5>Change Password</h5>
                                <div class="mb-3">
                                    <label for="currentPassword" class="form-label">Current Password *</label>
                                    <input type="password" class="form-control" id="currentPassword" name="currentPassword" required>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="newPassword" class="form-label">New Password *</label>
                                        <input type="password" class="form-control" id="newPassword" name="newPassword" required>
                                        <div class="form-text">Minimum 8 characters with letters and numbers</div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="confirmPassword" class="form-label">Confirm New Password *</label>
                                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                                    </div>
                                </div>
                            </div>

                            <div class="form-section">
                                <h5>Two-Factor Authentication</h5>
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="twoFactorEnabled" <%= customer.two_factor_enabled ? 'checked' : '' %>>
                                    <label class="form-check-label" for="twoFactorEnabled">
                                        Enable Two-Factor Authentication
                                    </label>
                                </div>
                                <p class="text-muted">
                                    <small>Add an extra layer of security to your account by requiring a verification code in addition to your password.</small>
                                </p>
                            </div>

                            <div class="form-section">
                                <h5>Login Sessions</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Device</th>
                                                <th>Location</th>
                                                <th>Last Active</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>
                                                    <i class="bi bi-laptop me-2"></i> Current Session
                                                </td>
                                                <td>Unknown</td>
                                                <td>Just now</td>
                                                <td>
                                                    <span class="badge bg-success">Active</span>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="logoutAllSessions()">
                                    <i class="bi bi-box-arrow-right me-2"></i> Logout All Other Sessions
                                </button>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-shield-lock me-2"></i> Update Security Settings
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Preferences Tab -->
                    <div class="tab-pane fade" id="preferences" role="tabpanel">
                        <form id="preferencesForm" onsubmit="updatePreferences(event)">
                            <div class="form-section">
                                <h5>Communication Preferences</h5>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailNewsletter" <%= customer.email_newsletter ? 'checked' : '' %>>
                                    <label class="form-check-label" for="emailNewsletter">
                                        Subscribe to newsletter
                                    </label>
                                    <div class="form-text">Receive updates about new products, promotions, and special offers.</div>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailOrderUpdates" <%= customer.email_order_updates ? 'checked' : '' %>>
                                    <label class="form-check-label" for="emailOrderUpdates">
                                        Order updates via email
                                    </label>
                                    <div class="form-text">Receive notifications about your order status and shipping updates.</div>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="smsNotifications" <%= customer.sms_notifications ? 'checked' : '' %>>
                                    <label class="form-check-label" for="smsNotifications">
                                        SMS notifications
                                    </label>
                                    <div class="form-text">Receive important updates via text message.</div>
                                </div>
                            </div>

                            <div class="form-section">
                                <h5>Privacy Settings</h5>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="profilePublic" <%= customer.profile_public ? 'checked' : '' %>>
                                    <label class="form-check-label" for="profilePublic">
                                        Make profile public
                                    </label>
                                    <div class="form-text">Allow other users to see your public profile and reviews.</div>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="dataSharing" <%= customer.data_sharing ? 'checked' : '' %>>
                                    <label class="form-check-label" for="dataSharing">
                                        Allow data sharing for analytics
                                    </label>
                                    <div class="form-text">Help us improve our services by sharing anonymous usage data.</div>
                                </div>
                            </div>

                            <div class="form-section">
                                <h5>Language & Region</h5>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="language" class="form-label">Language</label>
                                        <select class="form-select" id="language" name="language">
                                            <option value="en" <%= customer.language === 'en' ? 'selected' : '' %>>English</option>
                                            <option value="es" <%= customer.language === 'es' ? 'selected' : '' %>>Spanish</option>
                                            <option value="fr" <%= customer.language === 'fr' ? 'selected' : '' %>>French</option>
                                            <option value="de" <%= customer.language === 'de' ? 'selected' : '' %>>German</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="currency" class="form-label">Currency</label>
                                        <select class="form-select" id="currency" name="currency">
                                            <option value="USD" <%= customer.currency === 'USD' ? 'selected' : '' %>>US Dollar ($)</option>
                                            <option value="EUR" <%= customer.currency === 'EUR' ? 'selected' : '' %>>Euro (€)</option>
                                            <option value="GBP" <%= customer.currency === 'GBP' ? 'selected' : '' %>>British Pound (£)</option>
                                            <option value="CAD" <%= customer.currency === 'CAD' ? 'selected' : '' %>>Canadian Dollar (C$)</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="timezone" class="form-label">Timezone</label>
                                    <select class="form-select" id="timezone" name="timezone">
                                        <option value="UTC" <%= customer.timezone === 'UTC' ? 'selected' : '' %>>UTC</option>
                                        <option value="America/New_York" <%= customer.timezone === 'America/New_York' ? 'selected' : '' %>>Eastern Time (ET)</option>
                                        <option value="America/Chicago" <%= customer.timezone === 'America/Chicago' ? 'selected' : '' %>>Central Time (CT)</option>
                                        <option value="America/Denver" <%= customer.timezone === 'America/Denver' ? 'selected' : '' %>>Mountain Time (MT)</option>
                                        <option value="America/Los_Angeles" <%= customer.timezone === 'America/Los_Angeles' ? 'selected' : '' %>>Pacific Time (PT)</option>
                                    </select>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save me-2"></i> Save Preferences
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Address Modal -->
    <div class="modal fade" id="addAddressModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="addAddressForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="addressLabel" class="form-label">Address Label</label>
                                <input type="text" class="form-control" id="addressLabel" name="label" placeholder="Home, Work, etc.">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="addressType" class="form-label">Address Type</label>
                                <select class="form-select" id="addressType" name="type">
                                    <option value="shipping">Shipping Address</option>
                                    <option value="billing">Billing Address</option>
                                    <option value="both">Both Shipping & Billing</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="street" class="form-label">Street Address *</label>
                            <input type="text" class="form-control" id="street" name="street" required>
                        </div>
                        <div class="mb-3">
                            <label for="street2" class="form-label">Apartment, Suite, Unit (Optional)</label>
                            <input type="text" class="form-control" id="street2" name="street2">
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="city" class="form-label">City *</label>
                                <input type="text" class="form-control" id="city" name="city" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="state" class="form-label">State/Province *</label>
                                <input type="text" class="form-control" id="state" name="state" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="zipCode" class="form-label">ZIP/Postal Code *</label>
                                <input type="text" class="form-control" id="zipCode" name="zip_code" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="country" class="form-label">Country *</label>
                                <select class="form-select" id="country" name="country" required>
                                    <option value="US">United States</option>
                                    <option value="CA">Canada</option>
                                    <option value="UK">United Kingdom</option>
                                    <option value="AU">Australia</option>
                                    <option value="DE">Germany</option>
                                    <option value="FR">France</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="setAsDefault" name="is_default">
                            <label class="form-check-label" for="setAsDefault">
                                Set as default address
                            </label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="saveAddress()">Save Address</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Account Modal -->
    <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete your account?</p>
                    <p class="text-danger">
                        <strong>Warning:</strong> This action cannot be undone. All your data, including order history, addresses, and preferences will be permanently deleted.
                    </p>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="confirmDelete">
                        <label class="form-check-label" for="confirmDelete">
                            I understand that this action is irreversible
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" onclick="deleteAccount()" disabled id="deleteAccountBtn">
                        Delete My Account
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Enable delete account button when checkbox is checked
        document.getElementById('confirmDelete')?.addEventListener('change', function() {
            document.getElementById('deleteAccountBtn').disabled = !this.checked;
        });

        // Upload avatar
        function uploadAvatar(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            if (!file.type.startsWith('image/')) {
                alert('Please select an image file.');
                return;
            }
            
            if (file.size > 5 * 1024 * 1024) { // 5MB limit
                alert('Image size should be less than 5MB.');
                return;
            }
            
            const formData = new FormData();
            formData.append('avatar', file);
            
            fetch('/customer/profile/avatar', {
                method: 'POST',
                body: formData
            }).then(response => {
                if (response.ok) {
                    return response.json();
                }
                throw new Error('Upload failed');
            }).then(data => {
                if (data.avatarUrl) {
                    // Update avatar preview
                    const avatar = document.querySelector('.profile-avatar');
                    avatar.innerHTML = `<img src="${data.avatarUrl}" alt="Avatar" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">`;
                    avatar.classList.remove('editable');
                }
                alert('Avatar updated successfully!');
            }).catch(error => {
                console.error('Error:', error);
                alert('Failed to upload avatar. Please try again.');
            });
        }

        // Update personal info
        function updatePersonalInfo(event) {
            event.preventDefault();
            
            const formData = {
                firstName: document.getElementById('firstName').value,
                lastName: document.getElementById('lastName').value,
                email: document.getElementById('email').value,
                phone: document.getElementById('phone').value,
                birthDate: document.getElementById('birthDate').value,
                gender: document.getElementById('gender').value
            };
            
            fetch('/customer/profile', {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(formData)
            }).then(response => {
                if (response.ok) {
                    alert('Profile updated successfully!');
                    location.reload();
                } else {
                    alert('Failed to update profile. Please try again.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        // Update security settings
        function updateSecurity(event) {
            event.preventDefault();
            
            const currentPassword = document.getElementById('currentPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            
            if (newPassword !== confirmPassword) {
                alert('New passwords do not match.');
                return;
            }
            
            if (newPassword.length < 8) {
                alert('New password must be at least 8 characters long.');
                return;
            }
            
            const formData = {
                currentPassword: currentPassword,
                newPassword: newPassword,
                twoFactorEnabled: document.getElementById('twoFactorEnabled').checked
            };
            
            fetch('/customer/profile/security', {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(formData)
            }).then(response => {
                if (response.ok) {
                    alert('Security settings updated successfully!');
                    document.getElementById('securityForm').reset();
                } else {
                    alert('Failed to update security settings. Please check your current password.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        // Update preferences
        function updatePreferences(event) {
            event.preventDefault();
            
            const formData = {
                emailNewsletter: document.getElementById('emailNewsletter').checked,
                emailOrderUpdates: document.getElementById('emailOrderUpdates').checked,
                smsNotifications: document.getElementById('smsNotifications').checked,
                profilePublic: document.getElementById('profilePublic').checked,
                dataSharing: document.getElementById('dataSharing').checked,
                language: document.getElementById('language').value,
                currency: document.getElementById('currency').value,
                timezone: document.getElementById('timezone').value
            };
            
            fetch('/customer/profile/preferences', {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(formData)
            }).then(response => {
                if (response.ok) {
                    alert('Preferences updated successfully!');
                } else {
                    alert('Failed to update preferences.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        // Address management functions
        function saveAddress() {
            const form = document.getElementById('addAddressForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            fetch('/customer/addresses', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            }).then(response => {
                if (response.ok) {
                    alert('Address saved successfully!');
                    bootstrap.Modal.getInstance(document.getElementById('addAddressModal')).hide();
                    location.reload();
                } else {
                    alert('Failed to save address.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        function editAddress(addressId) {
            // In a real application, you would load address data and show edit modal
            alert('Edit address functionality would load address ' + addressId + ' for editing.');
        }

        function setDefaultAddress(addressId) {
            if (!confirm('Set this as your default address?')) return;
            
            fetch(`/customer/addresses/${addressId}/default`, {
                method: 'PUT'
            }).then(response => {
                if (response.ok) {
                    alert('Default address updated!');
                    location.reload();
                } else {
                    alert('Failed to update default address.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        function deleteAddress(addressId) {
            if (!confirm('Are you sure you want to delete this address?')) return;
            
            fetch(`/customer/addresses/${addressId}`, {
                method: 'DELETE'
            }).then(response => {
                if (response.ok) {
                    alert('Address deleted!');
                    location.reload();
                } else {
                    alert('Failed to delete address.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        function logoutAllSessions() {
            if (!confirm('Logout from all devices except this one?')) return;
            
            fetch('/customer/sessions/logout-all', {
                method: 'POST'
            }).then(response => {
                if (response.ok) {
                    alert('All other sessions have been logged out.');
                } else {
                    alert('Failed to logout sessions.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }

        function deleteAccount() {
            if (!confirm('This will permanently delete your account and all data. Are you absolutely sure?')) return;
            
            fetch('/customer/profile', {
                method: 'DELETE'
            }).then(response => {
                if (response.ok) {
                    alert('Account deleted successfully. You will be redirected to the homepage.');
                    window.location.href = '/';
                } else {
                    alert('Failed to delete account.');
                }
            }).catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }
    </script>
</body>
</html>