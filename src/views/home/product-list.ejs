<div class="row g-4">
    <!-- Filters Sidebar -->
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm p-4 sticky-lg-top" style="top: 2rem;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Filters</h5>
                <a href="/products" class="small text-decoration-none fw-semibold">Clear All</a>
            </div>
            
            <form action="/products" method="GET">
                <!-- Search -->
                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Search</label>
                    <div class="input-group">
                        <input type="text" name="search" class="form-control bg-light border-0" placeholder="Product name..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                        <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i></button>
                    </div>
                </div>
                
                <!-- Category -->
                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Category</label>
                    <select name="category" class="form-select bg-light border-0" onchange="this.form.submit()">
                        <option value="all" <%= typeof categorySlug === 'undefined' || categorySlug === 'all' ? 'selected' : '' %>>All Categories</option>
                        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.slug %>" <%= typeof categorySlug !== 'undefined' && categorySlug === category.slug ? 'selected' : '' %>>
                                    <%= category.name %>
                                </option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
                
                <!-- Price Range -->
                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Price Range</label>
                    <div class="row g-2">
                        <div class="col-6">
                            <input type="number" name="minPrice" class="form-control bg-light border-0 small" placeholder="Min" value="<%= typeof minPrice !== 'undefined' ? minPrice : '' %>">
                        </div>
                        <div class="col-6">
                            <input type="number" name="maxPrice" class="form-control bg-light border-0 small" placeholder="Max" value="<%= typeof maxPrice !== 'undefined' ? maxPrice : '' %>">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-outline-primary btn-sm w-100 mt-3 rounded-pill fw-bold">Apply Price</button>
                </div>
            </form>
        </div>
    </div>
    
    <!-- Product Grid -->
    <div class="col-lg-9">
        <!-- Results Info -->
        <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-3 shadow-sm">
            <p class="mb-0 text-muted small">
                Showing <span class="fw-bold text-dark"><%= products.length %></span> products
                <% if (typeof search !== 'undefined' && search) { %> for "<span class="fw-bold text-dark"><%= search %></span>"<% } %>
            </p>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm border-0 bg-light" style="width: 150px;">
                    <option>Sort by: Newest</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                </select>
            </div>
        </div>
        
        <!-- Products -->
        <div class="row g-4">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 border-0 shadow-sm transition-hover overflow-hidden position-relative">
                            <div class="card-img-top placeholder-img product-placeholder">
                                <% if (product.image_url) { %>
                                    <img src="<%= product.image_url %>" alt="<%= product.name %>" class="img-fluid object-fit-cover w-100 h-100">
                                <% } else { %>
                                    <i class="fas fa-image fa-3x"></i>
                                <% } %>
                            </div>
                            <div class="card-body p-4">
                                <span class="badge bg-light text-primary mb-2 px-2 py-1"><%= product.category_name || 'General' %></span>
                                <h6 class="card-title fw-bold mb-2">
                                    <a href="/products/<%= product.slug %>" class="text-dark text-decoration-none stretched-link"><%= product.name %></a>
                                </h6>
                                <p class="card-text text-muted small mb-3 text-truncate"><%= product.description %></p>
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <span class="h5 fw-bold text-primary mb-0">$<%= product.price %></span>
                                    <button class="btn btn-primary btn-sm rounded-circle shadow-sm z-3 position-relative add-to-cart" 
                                            data-product-id="<%= product.id %>" 
                                            data-product-name="<%= product.name %>" 
                                            data-product-price="<%= product.price %>"
                                            data-product-image="<%= product.image_url %>"
                                            data-product-stock="<%= product.stock_quantity %>"
                                            style="width: 32px; height: 32px; padding: 0;">
                                        <i class="fas fa-plus small"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <div class="mb-4 text-muted"><i class="fas fa-search fa-4x opacity-25"></i></div>
                    <h4 class="fw-bold">No products found</h4>
                    <p class="text-muted">Try adjusting your filters or search terms.</p>
                    <a href="/products" class="btn btn-primary rounded-pill px-4 mt-3 fw-bold">Clear All Filters</a>
                </div>
            <% } %>
        </div>
        
        <!-- Pagination -->
        <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item <%= !pagination.hasPrevPage ? 'disabled' : '' %>">
                        <a class="page-link rounded-circle border-0 me-2" href="?page=<%= pagination.currentPage - 1 %>">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                    <% for(let i = 1; i <= pagination.totalPages; i++) { %>
                        <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
                            <a class="page-link rounded-circle border-0 mx-1" href="?page=<%= i %>"><%= i %></a>
                        </li>
                    <% } %>
                    <li class="page-item <%= !pagination.hasNextPage ? 'disabled' : '' %>">
                        <a class="page-link rounded-circle border-0 ms-2" href="?page=<%= pagination.currentPage + 1 %>">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        <% } %>
    </div>
</div>
