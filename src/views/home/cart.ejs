<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mb-4">
            <h2 class="fw-bold mb-5">Shopping Cart</h2>
            
            <% if (typeof cartItems !== 'undefined' && cartItems.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-borderless align-middle">
                        <thead>
                            <tr class="border-bottom small text-uppercase text-muted fw-bold">
                                <th class="pb-3" style="min-width: 300px;">Product</th>
                                <th class="pb-3 text-center">Price</th>
                                <th class="pb-3 text-center">Quantity</th>
                                <th class="pb-3 text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cartItems.forEach(item => { %>
                                <tr class="border-bottom">
                                    <td class="py-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-3 overflow-hidden me-3" style="width: 80px; height: 80px;">
                                                <div class="placeholder-img h-100"><i class="fas fa-image"></i></div>
                                            </div>
                                            <div>
                                                <h6 class="fw-bold mb-1"><%= item.name %></h6>
                                                <button class="btn btn-sm btn-link text-danger p-0 text-decoration-none fw-semibold">Remove</button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 text-center fw-bold text-muted">$<%= item.price %></td>
                                    <td class="py-4 text-center">
                                        <div class="d-inline-flex border rounded-3 p-1">
                                            <button class="btn btn-sm px-2 py-0"><i class="fas fa-minus small"></i></button>
                                            <span class="px-3 fw-bold"><%= item.quantity %></span>
                                            <button class="btn btn-sm px-2 py-0"><i class="fas fa-plus small"></i></button>
                                        </div>
                                    </td>
                                    <td class="py-4 text-end fw-bold text-primary">$<%= (item.price * item.quantity).toFixed(2) %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                
                <div class="d-flex justify-content-between mt-4">
                    <a href="/products" class="btn btn-link text-decoration-none fw-bold"><i class="fas fa-arrow-left me-2"></i> Continue Shopping</a>
                    <button class="btn btn-outline-secondary rounded-pill fw-bold">Update Cart</button>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <div class="mb-4 opacity-10"><i class="fas fa-shopping-cart fa-5x"></i></div>
                    <h4 class="fw-bold mb-3">Your cart is empty</h4>
                    <p class="text-muted mb-5">Looks like you haven't added anything to your cart yet.</p>
                    <a href="/products" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-sm">Start Shopping</a>
                </div>
            <% } %>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 sticky-lg-top" style="top: 2rem;">
            <h5 class="fw-bold mb-4">Order Summary</h5>
            
            <div class="d-flex justify-content-between mb-3 text-muted">
                <span>Subtotal</span>
                <span class="fw-bold">$0.00</span>
            </div>
            <div class="d-flex justify-content-between mb-3 text-muted">
                <span>Shipping</span>
                <span class="fw-bold text-success">Calculated at checkout</span>
            </div>
            <hr class="my-4">
            <div class="d-flex justify-content-between mb-5 align-items-end">
                <span class="fw-bold h5 mb-0">Total</span>
                <span class="fw-bold h4 text-primary mb-0">$0.00</span>
            </div>
            
            <a href="/checkout" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm mb-3">Proceed to Checkout</a>
            <div class="text-center small text-muted">
                <i class="fas fa-shield-halved me-1"></i> Secure and encrypted checkout
            </div>
        </div>
    </div>
</div>
