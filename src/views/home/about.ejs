<style>
    .hero-about {
        background: linear-gradient(rgba(79, 70, 229, 0.85), rgba(79, 70, 229, 0.85)), url('/images/hero-bg.webp');
        background-size: cover;
        background-position: center;
        color: #fff;
        padding: 6rem 0;
        margin-top: -1.5rem;
        border-radius: 0 0 2rem 2rem;
    }

    .value-icon {
        font-size: 2.5rem;
        color: var(--primary-color);
    }

    .stat-card {
        border-radius: 1rem;
        background: linear-gradient(135deg, var(--primary-color) 0%, #6366f1 100%);
        color: #fff;
        padding: 2.5rem;
        height: 100%;
        border: none;
    }

    .team-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--light-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: var(--primary-color);
        border: 3px solid var(--border-color);
    }
</style>

<section class="hero-about text-center mb-5">
    <div class="container">
        <span class="badge bg-white text-primary mb-3 px-3 py-2 rounded-pill fw-bold">Who We Are</span>
        <h1 class="display-4 fw-bold">Built to Elevate Everyday Shopping</h1>
        <p class="lead mx-auto opacity-90" style="max-width: 720px;">
            Since day one, <%= appName %> has been focused on curating high-quality products, delivering delightful
            experiences, and supporting the communities that trust us.
        </p>
    </div>
</section>

<!-- Our Story -->
<section class="mb-5 py-4">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <h2 class="section-title">Our Story</h2>
            <p class="text-muted mb-4">
                What started as a small marketplace among friends has grown into a complete commerce experience. We
                set out to remove friction from online shopping—simplifying discovery, improving transparency, and
                ensuring customer satisfaction at every step.
            </p>
            <p class="text-muted">
                Today, our catalog spans hundreds of carefully vetted brands. We partner with local artisans and
                trusted manufacturers to bring you products that stand the test of time, all backed by responsive
                support and flexible fulfillment options.
            </p>
        </div>
        <div class="col-lg-6">
            <div class="row g-4">
                <div class="col-sm-6">
                    <div class="card stat-card text-center">
                        <h3 class="display-6 fw-bold mb-1">50K+</h3>
                        <p class="mb-0 opacity-75">Orders Delivered</p>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card stat-card text-center" style="background: linear-gradient(135deg, var(--success-color) 0%, var(--primary-color) 100%);">
                        <h3 class="display-6 fw-bold mb-1">4.9/5</h3>
                        <p class="mb-0 opacity-75">Average Rating</p>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card stat-card text-center" style="background: linear-gradient(135deg, var(--warning-color) 0%, #f59e0b 100%);">
                        <h3 class="display-6 fw-bold mb-1">98%</h3>
                        <p class="mb-0 opacity-75">On-Time Delivery</p>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card stat-card text-center" style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);">
                        <h3 class="display-6 fw-bold mb-1">120+</h3>
                        <p class="mb-0 opacity-75">Global Suppliers</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Core Values -->
<section class="mb-5 py-5">
    <div class="text-center mb-5">
        <h2 class="section-title d-inline-block">Our Core Values</h2>
        <p class="text-muted mt-2">The principles that guide every decision we make.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-white p-4">
                <div class="card-body text-center">
                    <div class="value-icon mb-4">
                        <i class="fas fa-handshake"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Customer Obsession</h5>
                    <p class="text-muted mb-0">
                        We design every service with your needs first—prioritizing transparency, speed, and trust.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 bg-white p-4">
                <div class="card-body text-center">
                    <div class="value-icon mb-4">
                        <i class="fas fa-seedling"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Sustainable Growth</h5>
                    <p class="text-muted mb-0">
                        From packaging to partnerships, we invest in responsible solutions that minimize impact.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 bg-white p-4">
                <div class="card-body text-center">
                    <div class="value-icon mb-4">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Relentless Innovation</h5>
                    <p class="text-muted mb-0">
                        We continuously experiment with tools, logistics, and personalization to improve your journey.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Leadership Team -->
<section class="mb-5 pb-5">
    <div class="text-center mb-5">
        <h2 class="section-title d-inline-block">Meet the Leadership</h2>
        <p class="text-muted mt-2">Experts in commerce, logistics, and customer experience.</p>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-white text-center p-4">
                <div class="team-avatar mx-auto mb-4">
                    <i class="fas fa-user-tie"></i>
                </div>
                <h5 class="fw-bold mb-1">Alex Morgan</h5>
                <p class="text-primary fw-semibold mb-3">Founder & CEO</p>
                <p class="text-muted mb-0 small">
                    Visionary operator focused on building long-term partnerships with suppliers and communities.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-white text-center p-4">
                <div class="team-avatar mx-auto mb-4">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h5 class="fw-bold mb-1">Priya Shah</h5>
                <p class="text-primary fw-semibold mb-3">Chief Operations Officer</p>
                <p class="text-muted mb-0 small">
                    Leads logistics innovation and operational excellence to keep fulfillment fast and predictable.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-white text-center p-4">
                <div class="team-avatar mx-auto mb-4">
                    <i class="fas fa-heart"></i>
                </div>
                <h5 class="fw-bold mb-1">Gabriel Costa</h5>
                <p class="text-primary fw-semibold mb-3">Head of Customer Experience</p>
                <p class="text-muted mb-0 small">
                    Champions user feedback loops, loyalty programs, and support training across the globe.
                </p>
            </div>
        </div>
    </div>
</section>
