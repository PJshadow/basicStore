<style>
    .hero-section {
        background: linear-gradient(rgba(15, 23, 42, 0.8), rgba(15, 23, 42, 0.8)), url('/images/hero-bg.webp');
        background-size: cover;
        background-position: center;
        color: white;
        padding: 6rem 0;
        margin-top: -1.5rem;
        margin-bottom: 4rem;
        border-radius: 0 0 2rem 2rem;
    }
    .feature-icon {
        font-size: 2.5rem;
        color: var(--primary-color);
        margin-bottom: 1.25rem;
    }
</style>

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container">
        <h1 class="display-3 fw-bold mb-4">Welcome to <%= appName %></h1>
        <p class="lead mb-5 opacity-90 mx-auto" style="max-width: 700px;">Discover amazing products at unbeatable prices. Quality you can trust, service you'll love.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="/products" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold">
                <i class="fas fa-shopping-bag me-2"></i> Shop Now
            </a>
            <a href="/about" class="btn btn-outline-light btn-lg px-5 py-3 rounded-pill fw-bold">
                Learn More
            </a>
        </div>
    </div>
</section>

<!-- Featured Categories -->
<section class="mb-5">
    <div class="container">
        <h2 class="section-title">Shop by Category</h2>
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="card category-card h-100">
                    <div class="card-img-top placeholder-img category-placeholder">
                        <i class="fas fa-laptop fa-3x"></i>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Electronics</h5>
                        <a href="/products?category=electronics" class="btn btn-sm btn-outline-primary stretched-link mt-2">Browse</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card category-card h-100">
                    <div class="card-img-top placeholder-img category-placeholder" style="background: linear-gradient(135deg, #10b981 0%, #34d399 100%);">
                        <i class="fas fa-tshirt fa-3x"></i>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Fashion</h5>
                        <a href="/products?category=fashion" class="btn btn-sm btn-outline-primary stretched-link mt-2">Browse</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card category-card h-100">
                    <div class="card-img-top placeholder-img category-placeholder" style="background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);">
                        <i class="fas fa-home fa-3x"></i>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Home</h5>
                        <a href="/products?category=home" class="btn btn-sm btn-outline-primary stretched-link mt-2">Browse</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card category-card h-100">
                    <div class="card-img-top placeholder-img category-placeholder" style="background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);">
                        <i class="fas fa-running fa-3x"></i>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Sports</h5>
                        <a href="/products?category=sports" class="btn btn-sm btn-outline-primary stretched-link mt-2">Browse</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="py-5 bg-white rounded-4 shadow-sm mb-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h2 class="section-title mb-0">Featured Products</h2>
                <p class="text-muted mt-2">Our most popular items this week</p>
            </div>
            <a href="/products" class="btn btn-link fw-semibold">View All <i class="fas fa-arrow-right ms-1"></i></a>
        </div>
        
        <div class="row g-4">
            <% if (typeof featuredProducts !== 'undefined' && featuredProducts.length > 0) { %>
                <% featuredProducts.forEach(product => { %>
                    <div class="col-lg-3 col-md-6">
                        <div class="card h-100 border-0 shadow-sm transition-hover position-relative">
                            <div class="card-img-top placeholder-img product-placeholder">
                                <% if (product.image_url) { %>
                                    <img src="<%= product.image_url %>" alt="<%= product.name %>" class="img-fluid object-fit-cover w-100 h-100">
                                <% } else { %>
                                    <i class="fas fa-image fa-3x"></i>
                                <% } %>
                            </div>
                            <div class="card-body">
                                <span class="badge bg-primary-subtle text-primary mb-2"><%= product.category_name || 'General' %></span>
                                <h5 class="card-title fw-bold">
                                    <a href="/products/<%= product.slug %>" class="text-dark text-decoration-none stretched-link"><%= product.name %></a>
                                </h5>
                                <p class="card-text text-muted small"><%= product.short_description || (product.description ? product.description.substring(0, 50) + '...' : '') %></p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="h5 fw-bold text-primary mb-0">$<%= product.price %></span>
                                    <button class="btn btn-primary btn-sm rounded-circle add-to-cart z-3 position-relative"
                                            data-product-id="<%= product.id %>"
                                            data-product-name="<%= product.name %>"
                                            data-product-price="<%= product.price %>">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <!-- Fallback products if none in database (Product 1) -->
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm transition-hover position-relative">
                        <div class="card-img-top placeholder-img product-placeholder">
                            <i class="fas fa-headphones fa-4x"></i>
                        </div>
                        <div class="card-body">
                            <span class="badge bg-primary-subtle text-primary mb-2">Electronics</span>
                            <h5 class="card-title fw-bold">
                                <a href="/products/wireless-headphones" class="text-dark text-decoration-none stretched-link">Wireless Headphones</a>
                            </h5>
                            <p class="card-text text-muted small">Premium sound quality with noise cancellation</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="h5 fw-bold text-primary mb-0">$99.99</span>
                                <button class="btn btn-primary btn-sm rounded-circle add-to-cart z-3 position-relative"
                                        data-product-id="1"
                                        data-product-name="Wireless Headphones"
                                        data-product-price="99.99">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Product 2 -->
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm transition-hover position-relative">
                        <div class="card-img-top placeholder-img product-placeholder" style="background: linear-gradient(135deg, #0ea5e9 0%, #4f46e5 100%);">
                            <i class="fas fa-stopwatch fa-4x"></i>
                        </div>
                        <div class="card-body">
                            <span class="badge bg-primary-subtle text-primary mb-2">Gadgets</span>
                            <h5 class="card-title fw-bold">
                                <a href="/products/smart-watch" class="text-dark text-decoration-none stretched-link">Smart Watch</a>
                            </h5>
                            <p class="card-text text-muted small">Track fitness, receive notifications</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="h5 fw-bold text-primary mb-0">$199.99</span>
                                <button class="btn btn-primary btn-sm rounded-circle add-to-cart z-3 position-relative"
                                        data-product-id="2"
                                        data-product-name="Smart Watch"
                                        data-product-price="199.99">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Product 3 -->
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm transition-hover position-relative">
                        <div class="card-img-top placeholder-img product-placeholder" style="background: linear-gradient(135deg, #10b981 0%, #4f46e5 100%);">
                            <i class="fas fa-shopping-bag fa-4x"></i>
                        </div>
                        <div class="card-body">
                            <span class="badge bg-primary-subtle text-primary mb-2">Fashion</span>
                            <h5 class="card-title fw-bold">
                                <a href="/products/backpack" class="text-dark text-decoration-none stretched-link">Leather Backpack</a>
                            </h5>
                            <p class="card-text text-muted small">Durable water-resistant backpack</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="h5 fw-bold text-primary mb-0">$49.99</span>
                                <button class="btn btn-primary btn-sm rounded-circle add-to-cart z-3 position-relative"
                                        data-product-id="3"
                                        data-product-name="Leather Backpack"
                                        data-product-price="49.99">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Product 4 -->
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm transition-hover position-relative">
                        <div class="card-img-top placeholder-img product-placeholder" style="background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);">
                            <i class="fas fa-coffee fa-4x"></i>
                        </div>
                        <div class="card-body">
                            <span class="badge bg-primary-subtle text-primary mb-2">Home</span>
                            <h5 class="card-title fw-bold">
                                <a href="/products/coffee-maker" class="text-dark text-decoration-none stretched-link">Coffee Maker</a>
                            </h5>
                            <p class="card-text text-muted small">Programmable 12-cup coffee maker</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="h5 fw-bold text-primary mb-0">$79.99</span>
                                <button class="btn btn-primary btn-sm rounded-circle add-to-cart z-3 position-relative"
                                        data-product-id="4"
                                        data-product-name="Coffee Maker"
                                        data-product-price="79.99">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5 mb-5">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-4 card border-0 h-100 bg-light">
                    <div class="feature-icon">
                        <i class="fas fa-truck-fast"></i>
                    </div>
                    <h5 class="fw-bold">Free Shipping</h5>
                    <p class="text-muted mb-0">Free delivery on orders over $50. Fast and reliable service to your doorstep.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 card border-0 h-100 bg-light">
                    <div class="feature-icon">
                        <i class="fas fa-shield-halved"></i>
                    </div>
                    <h5 class="fw-bold">Secure Payment</h5>
                    <p class="text-muted mb-0">100% secure payment processing with industry-standard encryption.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 card border-0 h-100 bg-light">
                    <div class="feature-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h5 class="fw-bold">24/7 Support</h5>
                    <p class="text-muted mb-0">Our dedicated support team is here to help you anytime, day or night.</p>
                </div>
            </div>
        </div>
    </div>
</section>


