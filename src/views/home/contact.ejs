<style>
    .contact-hero {
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.9), rgba(15, 23, 42, 0.8)), url('/images/hero-bg.webp');
        background-size: cover;
        background-position: center;
        color: #fff;
        padding: 6rem 0;
        margin-top: -1.5rem;
        border-radius: 0 0 2rem 2rem;
    }

    .contact-card {
        border: none;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        border-radius: 1.5rem;
        overflow: hidden;
    }

    .contact-icon-box {
        width: 60px;
        height: 60px;
        border-radius: 1rem;
        background-color: var(--primary-color);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
    }
</style>

<section class="contact-hero text-center mb-5">
    <div class="container">
        <span class="badge bg-white text-primary mb-3 px-3 py-2 rounded-pill fw-bold">Customer Care</span>
        <h1 class="display-4 fw-bold">We're Here to Help</h1>
        <p class="lead mx-auto opacity-90" style="max-width: 720px;">
            Reach out anytime—our support team is ready to answer questions about orders, returns, products, or accounts.
        </p>
    </div>
</section>

<div class="row justify-content-center mb-5 pb-5">
    <div class="col-lg-10">
        <div class="card contact-card bg-white p-4 p-md-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold mb-3">Contact <%= appName %></h2>
                <p class="text-muted">Choose the channel that works best for you. We typically respond within 24 hours.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="p-4 border rounded-4 h-100 transition-hover">
                        <div class="contact-icon-box">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Email Support</h4>
                        <p class="text-muted mb-4">
                            Prefer writing? Drop us an email and we'll get back to you with a detailed response.
                        </p>
                        <a href="mailto:<%= contactEmail %>" class="btn btn-outline-primary fw-bold rounded-pill px-4">
                            <%= contactEmail %>
                        </a>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 border rounded-4 h-100 transition-hover">
                        <div class="contact-icon-box" style="background-color: #25d366;">
                            <i class="fab fa-whatsapp"></i>
                        </div>
                        <h4 class="fw-bold mb-3">WhatsApp Chat</h4>
                        <p class="text-muted mb-4">
                            Get instant help via WhatsApp. Perfect for quick questions about your ongoing orders.
                        </p>
                        <% if (whatsappLink) { %>
                            <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-success fw-bold rounded-pill px-4">
                                Start Chatting
                            </a>
                        <% } else { %>
                            <button class="btn btn-secondary fw-bold rounded-pill px-4" disabled>
                                Unavailable
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="mt-5 pt-4 text-center border-top">
                <p class="text-muted mb-4">Need answers right now? Check our most frequently asked questions.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/faq" class="btn btn-primary rounded-pill px-5 fw-bold">Browse FAQ</a>
                    <a href="/" class="btn btn-light rounded-pill px-5 fw-bold">Back Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
