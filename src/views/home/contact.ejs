<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - <%= appName %></title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        .contact-hero {
            background: linear-gradient(120deg, rgba(13,110,253,.9), rgba(0,0,0,.7)), url('/images/hero-bg.webp');
            background-size: cover;
            background-position: center;
            color: #fff;
            padding: 120px 0;
        }

        .contact-card {
            border-radius: 24px;
            border: none;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
        }

        .contact-chip {
            display: inline-flex;
            align-items: center;
            gap: .75rem;
            padding: .6rem 1rem;
            border-radius: 999px;
            background: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
            font-weight: 600;
        }

        .cta-btns .btn {
            min-width: 220px;
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <section class="contact-hero text-center">
        <div class="container">
            <span class="contact-chip mb-3"><i class="fas fa-headset"></i> Customer Care</span>
            <h1 class="display-4 fw-bold">We&apos;re Here to Help</h1>
            <p class="lead mx-auto" style="max-width: 720px;">
                Reach out anytime—our support team is ready to answer questions about orders, returns, products, or accounts.
            </p>
        </div>
    </section>

    <main class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card contact-card p-5 mb-4">
                        <div class="mb-4 text-center">
                            <h2 class="fw-semibold">Contact <%= appName %></h2>
                            <p class="text-muted">Choose the channel that works best for you</p>
                        </div>

                        <div class="row g-4 mb-5">
                            <div class="col-md-6">
                                <div class="border rounded-4 p-4 h-100 d-flex flex-column justify-content-between">
                                    <div>
                                        <h5>Email Support</h5>
                                        <p class="text-muted mb-3">
                                            Drop us a message and we&apos;ll reply within one business day.
                                        </p>
                                    </div>
                                    <a href="mailto:<%= contactEmail %>" class="text-decoration-none text-primary fw-semibold">
                                        <i class="fas fa-envelope me-2"></i><%= contactEmail %>
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-4 p-4 h-100 d-flex flex-column justify-content-between">
                                    <div>
                                        <h5>WhatsApp Sales</h5>
                                        <p class="text-muted mb-3">
                                            Tap the button to start a WhatsApp chat and get live updates about your orders.
                                        </p>
                                    </div>
                                    <% if (whatsappLink) { %>
                                        <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-success w-100">
                                            <i class="fab fa-whatsapp me-2"></i> Chat on WhatsApp
                                            <% if (whatsappNumber) { %>
                                                <span class="text-white ms-2 small">(<%= whatsappNumber %>)</span>
                                            <% } %>
                                        </a>
                                    <% } else { %>
                                        <button class="btn btn-secondary w-100" disabled>
                                            WhatsApp number unavailable
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="text-center cta-btns">
                            <a href="/faq" class="btn btn-outline-primary me-2"><i class="fas fa-question-circle me-1"></i> Browse FAQs</a>
                            <a href="/" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Back to Home</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="/js/main.js"></script>
</body>
</html>
