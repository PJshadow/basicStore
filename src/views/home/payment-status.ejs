<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-sm rounded-4 p-5">
                <div class="mb-4">
                    <% if (status === 'success') { %>
                        <div class="display-1 text-success mb-4">
                            <i class="fas fa-check-circle"></i>
                        </div>
                    <% } else if (status === 'pending') { %>
                        <div class="display-1 text-warning mb-4">
                            <i class="fas fa-clock"></i>
                        </div>
                    <% } else { %>
                        <div class="display-1 text-danger mb-4">
                            <i class="fas fa-times-circle"></i>
                        </div>
                    <% } %>
                </div>
                
                <h2 class="fw-bold mb-3"><%= title %></h2>
                <p class="text-muted mb-4"><%= message %></p>
                
                <div class="d-grid gap-2">
                    <a href="/" class="btn btn-primary py-3 rounded-pill fw-bold">Back to Home</a>
                    <% if (currentUser) { %>
                        <a href="/customer/orders" class="btn btn-outline-secondary py-3 rounded-pill fw-bold">View My Orders</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
