<div class="row g-5 pb-5">
    <!-- Billing Details -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
            <h4 class="fw-bold mb-5">Billing Details</h4>
            
            <form action="/checkout" method="POST">
                <input type="hidden" name="idempotencyKey" value="<%= idempotencyKey %>">
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label for="firstName" class="form-label fw-semibold">First Name</label>
                        <input type="text" class="form-control bg-light" id="firstName" name="first_name" value="<%= customerInfo ? customerInfo.first_name : '' %>" required>
                    </div>
                    <div class="col-md-6">
                        <label for="lastName" class="form-label fw-semibold">Last Name</label>
                        <input type="text" class="form-control bg-light" id="lastName" name="last_name" value="<%= customerInfo ? customerInfo.last_name : '' %>" required>
                    </div>
                </div>
                
                <div class="mb-4">
                    <label for="email" class="form-label fw-semibold">Email Address</label>
                    <input type="email" class="form-control bg-light" id="email" name="email" value="<%= customerInfo ? customerInfo.email : '' %>" required>
                </div>
                
                <div class="mb-4">
                    <label for="phone" class="form-label fw-semibold">Phone Number</label>
                    <input type="tel" class="form-control bg-light" id="phone" name="phone" value="<%= customerInfo ? customerInfo.phone : '' %>" required>
                </div>
                
                <div class="mb-4">
                    <label for="address" class="form-label fw-semibold">Street Address</label>
                    <input type="text" class="form-control bg-light mb-2" id="address" name="address" placeholder="House number and street name" value="<%= customerInfo ? customerInfo.address : '' %>" required>
                    <input type="text" class="form-control bg-light" name="address2" placeholder="Apartment, suite, unit, etc. (optional)">
                </div>
                
                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <label for="city" class="form-label fw-semibold">City</label>
                        <input type="text" class="form-control bg-light" id="city" name="city" value="<%= customerInfo ? customerInfo.city : '' %>" required>
                    </div>
                    <div class="col-md-4">
                        <label for="state" class="form-label fw-semibold">State</label>
                        <input type="text" class="form-control bg-light" id="state" name="state" value="<%= customerInfo ? customerInfo.state : '' %>" required>
                    </div>
                    <div class="col-md-4">
                        <label for="zipCode" class="form-label fw-semibold">ZIP Code</label>
                        <input type="text" class="form-control bg-light" id="zipCode" name="zip_code" value="<%= customerInfo ? customerInfo.zip_code : '' %>" required>
                    </div>
                </div>
                
                <h5 class="fw-bold mb-4">Payment Method</h5>
                <div class="p-3 bg-light rounded-4 mb-5 shadow-sm border border-primary-subtle">
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard" value="card" checked>
                        <label class="form-check-label fw-bold" for="creditCard">
                            Credit/Debit Card <i class="fas fa-credit-card ms-2 text-primary"></i>
                        </label>
                    </div>
                    <div class="ps-4">
                        <div class="mb-3">
                            <input type="text" class="form-control bg-white" placeholder="Card Number" required>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="text" class="form-control bg-white" placeholder="MM/YY" required>
                            </div>
                            <div class="col-md-6">
                                <input type="text" class="form-control bg-white" placeholder="CVC" required>
                            </div>
                        </div>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm">
                    Place Order
                </button>
            </form>
        </div>
    </div>
    
    <!-- Order Summary -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 sticky-lg-top" style="top: 2rem;">
            <h4 class="fw-bold mb-5">Your Order</h4>
            
            <div class="order-items mb-4">
                <% if (typeof cartItems !== 'undefined' && cartItems.length > 0) { %>
                    <% cartItems.forEach(item => { %>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-3 overflow-hidden me-3" style="width: 50px; height: 50px;">
                                    <% if (item.image) { %>
                                        <img src="<%= item.image %>" alt="<%= item.name %>" class="w-100 h-100 object-fit-cover">
                                    <% } else { %>
                                        <div class="placeholder-img h-100 small"><i class="fas fa-image"></i></div>
                                    <% } %>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0"><%= item.name %></h6>
                                    <small class="text-muted">Qty: <%= item.quantity %></small>
                                </div>
                            </div>
                            <span class="fw-bold text-dark">$<%= (item.price * item.quantity).toFixed(2) %></span>
                        </div>
                    <% }) %>
                <% } %>
            </div>
            
            <div class="p-4 bg-light rounded-4">
                <div class="d-flex justify-content-between mb-3 text-muted small">
                    <span>Subtotal</span>
                    <span class="fw-bold text-dark">$<%= typeof subtotal !== 'undefined' ? subtotal.toFixed(2) : '0.00' %></span>
                </div>
                
                <% if (typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
                    <div class="d-flex justify-content-between mb-3 text-muted small">
                        <div class="d-flex align-items-center">
                            <span>Coupon: <strong class="text-primary"><%= appliedCoupon.code %></strong></span>
                            <form action="/checkout/remove-coupon" method="POST" class="ms-2">
                                <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Remove Coupon">
                                    <i class="fas fa-times-circle"></i>
                                </button>
                            </form>
                        </div>
                        <span class="fw-bold text-danger">-$<%= discountAmount.toFixed(2) %></span>
                    </div>
                <% } %>

                <div class="d-flex justify-content-between mb-3 text-muted small">
                    <span>Shipping</span>
                    <span class="fw-bold text-success">Free Shipping</span>
                </div>
                <hr class="my-4 opacity-10">
                <div class="d-flex justify-content-between align-items-end">
                    <span class="fw-bold h5 mb-0">Total</span>
                    <span class="fw-bold h4 text-primary mb-0">$<%= typeof subtotal !== 'undefined' ? (subtotal - (typeof discountAmount !== 'undefined' ? discountAmount : 0)).toFixed(2) : '0.00' %></span>
                </div>
            </div>

            <div class="mt-4">
                <% if (!(typeof appliedCoupon !== 'undefined' && appliedCoupon)) { %>
                    <form action="/checkout/apply-coupon" method="POST" class="d-flex gap-2">
                        <input type="text" name="couponCode" class="form-control" placeholder="Coupon code" required>
                        <button type="submit" class="btn btn-outline-primary fw-bold px-4">Apply</button>
                    </form>
                <% } %>
            </div>
            
            <div class="mt-5 text-center text-muted small">
                <i class="fas fa-shield-halved mb-2 fa-2x d-block text-primary opacity-50"></i>
                Your personal data will be used to process your order, support your experience throughout this website, and for other purposes described in our <a href="/privacy" class="text-primary">privacy policy</a>.
            </div>
        </div>
    </div>
</div>
