<div class="row g-5">
    <!-- Product Images -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm overflow-hidden rounded-4 mb-3">
            <div class="placeholder-img product-placeholder bg-light" style="height: 500px;">
                <% if (product.images && product.images.length > 0) { %>
                    <img id="main-product-image" src="<%= product.images[0] %>" alt="<%= product.name %>" class="img-fluid object-fit-cover w-100 h-100">
                <% } else { %>
                    <i class="fas fa-image fa-5x"></i>
                <% } %>
            </div>
        </div>
        
        <!-- Thumbnails -->
        <% if (product.images && product.images.length > 1) { %>
            <div class="row g-3">
                <% product.images.forEach((img, index) => { %>
                    <div class="col-3 col-md-2">
                        <div class="ratio ratio-1x1 bg-white border rounded-3 overflow-hidden shadow-sm cursor-pointer thumbnail-item <%= index === 0 ? 'border-primary border-2' : '' %>" 
                             onclick="changeMainImage('<%= img %>', this)">
                            <img src="<%= img %>" alt="<%= product.name %>" class="img-fluid object-fit-cover w-100 h-100">
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
    
    <!-- Product Info -->
    <div class="col-lg-6">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item"><a href="/products" class="text-decoration-none">Products</a></li>
                <li class="breadcrumb-item active"><%= product.category_name || 'General' %></li>
            </ol>
        </nav>
        
        <h1 class="display-5 fw-bold mb-3"><%= product.name %></h1>
        
        <div class="d-flex align-items-center mb-4">
            <div class="text-warning me-2">
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star-half-alt"></i>
            </div>
            <span class="text-muted small">(<%= reviews.length %> customer reviews)</span>
        </div>
        
        <div class="h2 fw-bold text-primary mb-4">$<%= product.price %></div>
        
        <p class="text-muted mb-5 lead">
            <%= product.description %>
        </p>
        
        <div class="card border-0 bg-light p-4 rounded-4 mb-5">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Quantity</label>
                    <select id="product-quantity" class="form-select border-0 shadow-sm">
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                    </select>
                </div>
                <div class="col-md-8 pt-md-4">
                    <button class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm add-to-cart"
                            data-product-id="<%= product.id %>"
                            data-product-name="<%= product.name %>"
                            data-product-price="<%= product.price %>"
                            data-product-image="<%= (product.images && product.images.length > 0) ? product.images[0] : '' %>"
                            data-product-stock="<%= product.stock_quantity %>"
                            data-quantity-selector="#product-quantity">
                        <i class="fas fa-cart-plus me-2"></i> Add to Cart
                    </button>
                </div>
            </div>
        </div>
        
        <div class="row g-4 border-top pt-5">
            <div class="col-sm-6">
                <div class="d-flex align-items-center">
                    <div class="bg-primary-subtle text-primary rounded-circle p-3 me-3">
                        <i class="fas fa-truck-fast"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Free Delivery</h6>
                        <small class="text-muted">Orders over $50</small>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="d-flex align-items-center">
                    <div class="bg-primary-subtle text-primary rounded-circle p-3 me-3">
                        <i class="fas fa-rotate-left"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Easy Returns</h6>
                        <small class="text-muted">30-day money back</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function changeMainImage(src, element) {
    document.getElementById('main-product-image').src = src;
    
    // Update active border
    const thumbnails = document.querySelectorAll('.thumbnail-item');
    thumbnails.forEach(thumb => thumb.classList.remove('border-primary', 'border-2'));
    element.classList.add('border-primary', 'border-2');
}
</script>

<style>
.cursor-pointer {
    cursor: pointer;
}
.thumbnail-item {
    transition: all 0.2s;
}
.thumbnail-item:hover {
    opacity: 0.8;
}
</style>

<!-- Product Description Tabs -->
<div class="mt-5 pt-5">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-bottom-0 p-0">
            <ul class="nav nav-tabs border-bottom-0" id="productTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active px-4 py-3 fw-bold border-0 border-bottom-4 border-transparent" id="description-tab" data-bs-toggle="tab" data-bs-target="#description" type="button">Description</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link px-4 py-3 fw-bold border-0" id="specifications-tab" data-bs-toggle="tab" data-bs-target="#specifications" type="button">Specifications</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link px-4 py-3 fw-bold border-0" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button">Reviews</button>
                </li>
            </ul>
        </div>
        <div class="card-body p-4 p-md-5">
            <div class="tab-content" id="productTabsContent">
                <div class="tab-pane fade show active" id="description" role="tabpanel">
                    <h5 class="fw-bold mb-3">Product Overview</h5>
                    <p class="text-muted"><%= product.description %></p>
                    <p class="text-muted">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
                </div>
                <div class="tab-pane fade" id="specifications" role="tabpanel">
                    <table class="table table-striped">
                        <tr>
                            <th class="border-0">Material</th>
                            <td class="border-0 text-muted">Premium Quality</td>
                        </tr>
                        <tr>
                            <th>Weight</th>
                            <td class="text-muted">1.5 lbs</td>
                        </tr>
                        <tr>
                            <th>Warranty</th>
                            <td class="text-muted">12 Months</td>
                        </tr>
                    </table>
                </div>
                <div class="tab-pane fade" id="reviews" role="tabpanel">
                    <div class="text-center py-4">
                        <p class="text-muted mb-0">No reviews yet for this product.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
