<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - BasicStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %>
    
    <div class="container mt-4">
        <%- include('../partials/messages') %>
        
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/products">Products</a></li>
                <% if (product.categoryName) { %>
                    <li class="breadcrumb-item"><a href="/products?category=<%= product.category_id %>"><%= product.categoryName %></a></li>
                <% } %>
                <li class="breadcrumb-item active" aria-current="page"><%= product.name %></li>
            </ol>
        </nav>
        
        <div class="row">
            <!-- Product Images -->
            <div class="col-lg-6">
                <div class="card mb-4">
                    <div class="card-body p-3">
                        <!-- Main Image -->
                        <div class="text-center mb-3">
                            <img id="mainImage" src="<%= product.images[0] %>" 
                                 class="img-fluid rounded" 
                                 alt="<%= product.name %>"
                                 style="max-height: 400px; object-fit: contain;">
                        </div>
                        
                        <!-- Thumbnails -->
                        <% if (product.images.length > 1) { %>
                            <div class="d-flex justify-content-center flex-wrap gap-2">
                                <% product.images.forEach((image, index) => { %>
                                    <img src="<%= image %>" 
                                         class="img-thumbnail <%= index === 0 ? 'active' : '' %>" 
                                         style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;"
                                         onclick="document.getElementById('mainImage').src = this.src; 
                                                  document.querySelectorAll('.img-thumbnail').forEach(img => img.classList.remove('active'));
                                                  this.classList.add('active');"
                                         alt="<%= product.name %> - <%= index + 1 %>">
                                <% }); %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
            
            <!-- Product Info -->
            <div class="col-lg-6">
                <div class="card mb-4">
                    <div class="card-body">
                        <h1 class="h2 mb-2"><%= product.name %></h1>
                        
                        <!-- Category & SKU -->
                        <div class="mb-3">
                            <% if (product.categoryName) { %>
                                <span class="badge bg-secondary me-2"><%= product.categoryName %></span>
                            <% } %>
                            <% if (product.sku) { %>
                                <span class="text-muted">SKU: <%= product.sku %></span>
                            <% } %>
                        </div>
                        
                        <!-- Price -->
                        <div class="mb-4">
                            <% if (product.sale_price) { %>
                                <div class="d-flex align-items-center">
                                    <span class="h2 text-danger me-3">$<%= Number(product.sale_price).toFixed(2) %></span>
                                    <span class="h4 text-muted text-decoration-line-through">$<%= Number(product.price).toFixed(2) %></span>
                                    <span class="badge bg-danger ms-3">Save <%= ((Number(product.price) - Number(product.sale_price)) / Number(product.price) * 100).toFixed(0) %>%</span>
                                </div>
                            <% } else { %>
                                <span class="h2">$<%= Number(product.price).toFixed(2) %></span>
                            <% } %>
                        </div>
                        
                        <!-- Stock Status -->
                        <div class="mb-4">
                            <% if (product.stock_quantity > 0) { %>
                                <div class="alert alert-success d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    <div>
                                        <strong>In Stock</strong>
                                        <% if (product.stock_quantity < 10) { %>
                                            <span class="text-warning"> - Only <%= product.stock_quantity %> left!</span>
                                        <% } else { %>
                                            <span> - Available</span>
                                        <% } %>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="alert alert-danger d-flex align-items-center">
                                    <i class="bi bi-x-circle-fill me-2"></i>
                                    <div>
                                        <strong>Out of Stock</strong>
                                        <span> - Check back soon!</span>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                        
                        <!-- Add to Cart Form -->
                        <% if (product.stock_quantity > 0) { %>
                            <form action="/products/<%= product.id %>/add-to-cart" method="POST" class="mb-4">
                                <div class="row g-3 align-items-center">
                                    <div class="col-auto">
                                        <label for="quantity" class="col-form-label">Quantity:</label>
                                    </div>
                                    <div class="col-auto">
                                        <input type="number" 
                                               id="quantity" 
                                               name="quantity" 
                                               class="form-control" 
                                               value="1" 
                                               min="1" 
                                               max="<%= product.stock_quantity %>"
                                               style="width: 80px;">
                                    </div>
                                    <div class="col-auto">
                                        <button type="submit" class="btn btn-primary btn-lg">
                                            <i class="bi bi-cart-plus"></i> Add to Cart
                                        </button>
                                    </div>
                                </div>
                            </form>
                        <% } %>
                        
                        <!-- Short Description -->
                        <% if (product.short_description) { %>
                            <div class="mb-4">
                                <h5 class="h6">Quick Overview</h5>
                                <p class="text-muted"><%= product.short_description %></p>
                            </div>
                        <% } %>
                        
                        <!-- Features -->
                        <% if (product.features && product.features.length > 0) { %>
                            <div class="mb-4">
                                <h5 class="h6">Key Features</h5>
                                <ul class="list-unstyled">
                                    <% product.features.forEach(feature => { %>
                                        <li class="mb-1">
                                            <i class="bi bi-check text-success me-2"></i>
                                            <%= feature %>
                                        </li>
                                    <% }); %>
                                </ul>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Tabs -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <ul class="nav nav-tabs card-header-tabs" id="productTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="description-tab" data-bs-toggle="tab" data-bs-target="#description" type="button" role="tab">
                                    Description
                                </button>
                            </li>
                            <% if (product.specifications) { %>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button" role="tab">
                                        Specifications
                                    </button>
                                </li>
                            <% } %>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">
                                    Reviews (<%= reviews.length %>)
                                </button>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body">
                        <div class="tab-content" id="productTabsContent">
                            <!-- Description Tab -->
                            <div class="tab-pane fade show active" id="description" role="tabpanel">
                                <%= product.description || 'No description available.' %>
                            </div>
                            
                            <!-- Specifications Tab -->
                            <% if (product.specifications) { %>
                                <div class="tab-pane fade" id="specs" role="tabpanel">
                                    <table class="table table-striped">
                                        <tbody>
                                            <% Object.entries(product.specifications).forEach(([key, value]) => { %>
                                                <tr>
                                                    <th style="width: 30%"><%= key %></th>
                                                    <td><%= value %></td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                            
                            <!-- Reviews Tab -->
                            <div class="tab-pane fade" id="reviews" role="tabpanel">
                                <% if (reviews.length > 0) { %>
                                    <div class="row">
                                        <% reviews.forEach(review => { %>
                                            <div class="col-md-6 mb-3">
                                                <div class="card">
                                                    <div class="card-body">
                                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                                            <div>
                                                                <h6 class="mb-0"><%= review.user %></h6>
                                                                <small class="text-muted"><%= review.date %></small>
                                                            </div>
                                                            <div>
                                                                <% for (let i = 1; i <= 5; i++) { %>
                                                                    <% if (i <= review.rating) { %>
                                                                        <i class="bi bi-star-fill text-warning"></i>
                                                                    <% } else { %>
                                                                        <i class="bi bi-star text-warning"></i>
                                                                    <% } %>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                        <p class="mb-0"><%= review.comment %></p>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }); %>
                                    </div>
                                <% } else { %>
                                    <div class="text-center py-4">
                                        <i class="bi bi-chat-square-text display-1 text-muted"></i>
                                        <h5 class="mt-3">No reviews yet</h5>
                                        <p class="text-muted">Be the first to review this product!</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Related Products -->
        <% if (relatedProducts && relatedProducts.length > 0) { %>
            <div class="row mt-5">
                <div class="col-12">
                    <h3 class="mb-4">Related Products</h3>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                        <% relatedProducts.forEach(related => { %>
                            <div class="col">
                                <div class="card h-100">
                                    <% if (related.image_url) { %>
                                        <img src="<%= related.image_url %>" class="card-img-top" alt="<%= related.name %>" style="height: 150px; object-fit: cover;">
                                    <% } else { %>
                                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 150px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    <% } %>
                                    <div class="card-body">
                                        <h6 class="card-title">
                                            <a href="/products/<%= related.slug %>" class="text-decoration-none">
                                                <%= related.name %>
                                            </a>
                                        </h6>
                                        <p class="card-text">
                                            <span class="h6">$<%= Number(related.sale_price || related.price).toFixed(2) %></span>
                                            <% if (related.sale_price) { %>
                                                <small class="text-muted text-decoration-line-through ms-2">$<%= Number(related.price).toFixed(2) %></small>
                                            <% } %>
                                        </p>
                                        <a href="/products/<%= related.slug %>" class="btn btn-outline-primary btn-sm w-100">
                                            View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
    
    <%- include('../partials/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>