<div class="row justify-content-center py-5">
    <div class="col-md-6 text-center py-5">
        <div class="mb-5">
            <h1 class="display-1 fw-bold text-primary mb-0">404</h1>
            <div class="h3 fw-bold text-dark mt-0">Page Not Found</div>
            <div class="mt-4"><i class="fas fa-search fa-5x opacity-10"></i></div>
        </div>
        
        <p class="lead text-muted mb-5">
            <%= message || "The page you're looking for doesn't exist or has been moved." %>
        </p>
        
        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-sm">
                <i class="fas fa-home me-2"></i> Go Home
            </a>
            <a href="/products" class="btn btn-light rounded-pill px-5 py-3 fw-bold">
                Browse Products
            </a>
        </div>
    </div>
</div>
