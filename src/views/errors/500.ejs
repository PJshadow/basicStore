<div class="row justify-content-center py-5">
    <div class="col-md-8 text-center py-5">
        <div class="mb-5">
            <h1 class="display-1 fw-bold text-danger mb-0">500</h1>
            <div class="h3 fw-bold text-dark mt-0">Something went wrong!</div>
            <div class="mt-4"><i class="fas fa-triangle-exclamation fa-5x opacity-10"></i></div>
        </div>
        
        <p class="lead text-muted mb-4">
            Our server encountered an internal error. Our engineers have been notified.
        </p>

        <% if (error && error.stack) { %>
            <div class="text-start p-4 bg-light rounded-4 mb-5 shadow-sm border overflow-auto" style="max-height: 300px;">
                <p class="fw-bold mb-2">Technical details:</p>
                <code class="small text-danger"><%= message %></code>
                <pre class="small text-muted mt-3 mb-0" style="font-size: 0.75rem;"><%= error.stack %></pre>
            </div>
        <% } %>
        
        <div class="d-flex justify-content-center gap-3">
            <button onclick="window.location.reload()" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-sm">
                <i class="fas fa-rotate me-2"></i> Try Again
            </a>
            <a href="/" class="btn btn-light rounded-pill px-5 py-3 fw-bold">
                Go to Home
            </a>
        </div>
    </div>
</div>
