<div class="row justify-content-center py-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg p-4 p-md-5 text-center">
            <div class="mb-5">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-3" style="width: 64px; height: 64px;">
                    <i class="fas fa-key fa-lg"></i>
                </div>
                <h2 class="fw-bold">Forgot Password?</h2>
                <p class="text-muted">No worries, it happens! Enter your email and we'll send you a link to reset your password.</p>
            </div>
            
            <form action="/auth/forgot-password" method="POST" class="text-start">
                <div class="mb-4">
                    <label for="email" class="form-label fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                        <input type="email" class="form-control border-start-0 bg-light" id="email" name="email" placeholder="name@example.com" required autofocus>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold mb-4 shadow-sm">
                    Send Reset Link
                </button>
                
                <div class="text-center mt-3">
                    <a href="/auth/login" class="text-primary text-decoration-none fw-bold small"><i class="fas fa-arrow-left me-2 small"></i> Back to login</a>
                </div>
            </form>
        </div>
    </div>
</div>
