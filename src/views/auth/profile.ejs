<div class="row g-4 py-5">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-3" style="width: 100px; height: 100px; font-size: 2.5rem;">
                    <i class="fas fa-user"></i>
                </div>
                <h4 class="fw-bold mb-1"><%= currentUser.username %></h4>
                <p class="text-muted small"><%= currentUser.email %></p>
                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill small text-uppercase fw-bold"><%= currentUser.role %></span>
            </div>
            
            <hr class="my-4 opacity-10">
            
            <div class="list-group list-group-flush text-start border-0">
                <a href="/profile" class="list-group-item list-group-item-action border-0 rounded-3 active mb-1">
                    <i class="fas fa-user-circle me-2 opacity-75"></i> Personal Info
                </a>
                <a href="/orders" class="list-group-item list-group-item-action border-0 rounded-3 mb-1">
                    <i class="fas fa-box me-2 opacity-75"></i> My Orders
                </a>
                <a href="/settings" class="list-group-item list-group-item-action border-0 rounded-3 mb-1">
                    <i class="fas fa-cog me-2 opacity-75"></i> Account Settings
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
            <h4 class="fw-bold mb-5">Profile Information</h4>
            
            <form action="/profile" method="POST">
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase text-muted">Username</label>
                        <input type="text" class="form-control bg-light border-0 py-2" value="<%= currentUser.username %>" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase text-muted">Email Address</label>
                        <input type="email" class="form-control bg-light border-0 py-2" value="<%= currentUser.email %>" readonly>
                    </div>
                </div>
                
                <div class="mb-4">
                    <label for="displayName" class="form-label fw-bold small text-uppercase text-muted">Display Name</label>
                    <input type="text" class="form-control border-0 bg-light py-2" id="displayName" placeholder="Enter your public name">
                </div>
                
                <hr class="my-5 opacity-10">
                
                <h5 class="fw-bold mb-4">Change Password</h5>
                
                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <label for="newPassword" class="form-label fw-bold small text-uppercase text-muted">New Password</label>
                        <input type="password" class="form-control border-0 bg-light py-2" id="newPassword" placeholder="Minimum 8 characters">
                    </div>
                    <div class="col-md-6">
                        <label for="confirmPassword" class="form-label fw-bold small text-uppercase text-muted">Confirm New Password</label>
                        <input type="password" class="form-control border-0 bg-light py-2" id="confirmPassword" placeholder="Repeat new password">
                    </div>
                </div>
                
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
